.page {
  padding: 0 24rpx 24rpx;
  background: transparent;
  min-height: 100vh;
}

/* Tabs */
.tabs {
  display: flex;
  padding: 24rpx 0;
  gap: 24rpx;
}
.tab {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #2D8A74;
  background: rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}
.tab.active {
  background: #35C8B4;
  color: #FFF;
  font-weight: 600;
  border: 1rpx solid #35C8B4;
}

/* Filters */
.filters {
  margin-bottom: 20rpx;
}
.filter-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}
.chip {
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #2D8A74;
  background: rgba(255, 255, 255, 0.4);
  border: 1rpx solid rgba(53, 200, 180, 0.15);
}
.chip.active {
  background: rgba(53, 200, 180, 0.12);
  color: #35C8B4;
  border-color: #35C8B4;
}

/* Food List */
.food-card {
  display: flex;
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(53, 200, 180, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}
.food-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #F5F5F5;
}
.food-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.food-brand {
  font-size: 22rpx;
  color: #999;
}
.food-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A6B5A;
  margin: 6rpx 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.food-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 22rpx;
  color: #999;
}
.food-score {
  color: #35C8B4;
  font-weight: 600;
}
.food-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}
.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background: rgba(53, 200, 180, 0.1);
  color: #35C8B4;
  border-radius: 8rpx;
}

/* PGC List */
.pgc-card {
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(53, 200, 180, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}
.pgc-cover {
  width: 100%;
  height: 300rpx;
}
.pgc-content {
  padding: 20rpx;
}
.pgc-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A6B5A;
  margin-bottom: 12rpx;
}
.pgc-scores {
  display: flex;
  gap: 20rpx;
  font-size: 22rpx;
  color: #35C8B4;
}

/* Empty */
.empty {
  text-align: center;
  color: #999;
  padding: 80rpx 0;
  font-size: 28rpx;
}
