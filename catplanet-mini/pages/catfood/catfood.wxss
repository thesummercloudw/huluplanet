.page {
  padding: 0 24rpx 24rpx;
  background: #FFF5F0;
  min-height: 100vh;
}

/* Tabs */
.tabs {
  display: flex;
  padding: 24rpx 0;
  gap: 24rpx;
}
.tab {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #666;
  background: #FFF;
}
.tab.active {
  background: #FF8C69;
  color: #FFF;
  font-weight: 600;
}

/* Filters */
.filters {
  margin-bottom: 20rpx;
}
.filter-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}
.chip {
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #666;
  background: #FFF;
  border: 1rpx solid #EEE;
}
.chip.active {
  background: #FFF0EB;
  color: #FF8C69;
  border-color: #FF8C69;
}

/* Food List */
.food-card {
  display: flex;
  background: #FFF;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.food-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #F5F5F5;
}
.food-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.food-brand {
  font-size: 22rpx;
  color: #999;
}
.food-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin: 6rpx 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.food-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 22rpx;
  color: #999;
}
.food-score {
  color: #FF8C69;
  font-weight: 600;
}
.food-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}
.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background: #FFF5F0;
  color: #FF8C69;
  border-radius: 8rpx;
}

/* PGC List */
.pgc-card {
  background: #FFF;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.pgc-cover {
  width: 100%;
  height: 300rpx;
}
.pgc-content {
  padding: 20rpx;
}
.pgc-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}
.pgc-scores {
  display: flex;
  gap: 20rpx;
  font-size: 22rpx;
  color: #FF8C69;
}

/* Empty */
.empty {
  text-align: center;
  color: #999;
  padding: 80rpx 0;
  font-size: 28rpx;
}
