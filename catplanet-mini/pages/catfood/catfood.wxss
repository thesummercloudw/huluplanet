/* 猫粮评测列表 - 手绘涂鸦风 */
.page {
  padding: 0 24rpx 24rpx;
  background: transparent;
  min-height: 100vh;
  position: relative;
}

/* ===== 页面装饰 ===== */
.page-deco-top {
  position: absolute;
  top: 12rpx;
  right: 32rpx;
  pointer-events: none;
}
.deco-star {
  font-size: 28rpx;
  color: var(--color-primary);
  opacity: 0.5;
}
.deco-sparkle {
  font-size: 22rpx;
  color: var(--color-pink);
  opacity: 0.6;
  margin-left: 8rpx;
}

/* ===== Tabs ===== */
.tabs {
  display: flex;
  padding: 24rpx 0 16rpx;
  gap: 20rpx;
}
.tab {
  padding: 14rpx 36rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  background: var(--color-card);
  border: 2rpx solid rgba(56, 184, 232, 0.12);
  box-shadow: 0 2rpx 8rpx rgba(56, 184, 232, 0.04);
  transition: all 0.3s;
}
.tab.active {
  background: var(--color-primary);
  color: #FFF;
  font-weight: 600;
  border-color: var(--color-primary);
  box-shadow: 0 4rpx 12rpx rgba(56, 184, 232, 0.25);
}

/* ===== 搜索栏 ===== */
.search-bar {
  display: flex;
  align-items: center;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 14rpx 24rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid rgba(56, 184, 232, 0.12);
  box-shadow: 0 2rpx 8rpx rgba(56, 184, 232, 0.04);
}
.search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}
.search-input {
  flex: 1;
  margin-left: 12rpx;
  font-size: 26rpx;
  color: var(--color-text);
}
.search-clear {
  font-size: 24rpx;
  color: var(--color-placeholder);
  padding: 8rpx 12rpx;
}

/* ===== 筛选标签 ===== */
.filters {
  margin-bottom: 20rpx;
}
.filter-row {
  display: flex;
  gap: 14rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}
.chip {
  padding: 10rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  background: var(--color-card);
  border: 1.5rpx solid rgba(56, 184, 232, 0.12);
  transition: all 0.25s;
}
.chip.active {
  background: rgba(56, 184, 232, 0.1);
  color: var(--color-primary);
  border-color: var(--color-primary);
  font-weight: 600;
}

/* ===== 猫粮卡片 ===== */
.food-card {
  display: flex;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(56, 184, 232, 0.06);
  border: 2rpx solid rgba(56, 184, 232, 0.12);
  position: relative;
}
.food-img-wrap {
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--radius-md);
  flex-shrink: 0;
  overflow: hidden;
  background: var(--color-bg);
  border: 2rpx solid rgba(56, 184, 232, 0.1);
}
.food-img {
  width: 100%;
  height: 100%;
}
.food-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}
.food-brand {
  font-size: 22rpx;
  color: var(--color-placeholder);
  display: block;
}
.food-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text);
  margin: 6rpx 0 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 评分 + 评价数 */
.food-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 22rpx;
  color: var(--color-placeholder);
  margin-bottom: 6rpx;
}
.score-badge {
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: rgba(255, 184, 198, 0.15);
  padding: 4rpx 12rpx 4rpx 6rpx;
  border-radius: 20rpx;
}
.score-icon {
  width: 28rpx;
  height: 28rpx;
}
.score-num {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-text);
}
.food-reviews {
  font-size: 22rpx;
  color: var(--color-placeholder);
}

/* 营养数据行 */
.food-stats {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}
.stat-item {
  font-size: 20rpx;
  color: var(--color-primary);
  background: rgba(56, 184, 232, 0.08);
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 600;
}
.stat-price {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  margin-left: auto;
}

/* 标签 */
.food-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}
.tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  background: var(--color-secondary);
  color: var(--color-accent);
  border-radius: 20rpx;
  border: 1rpx solid rgba(142, 189, 60, 0.2);
}

/* ===== PGC 测评卡片 ===== */
.pgc-card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(56, 184, 232, 0.06);
  border: 2rpx solid rgba(56, 184, 232, 0.12);
}
.pgc-cover {
  width: 100%;
  height: 300rpx;
}
.pgc-content {
  padding: 24rpx;
}
.pgc-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 16rpx;
  line-height: 1.4;
}

/* PGC 评分条 */
.pgc-scores {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.pgc-score-item {
  display: flex;
  align-items: center;
}
.pgc-score-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  width: 72rpx;
  flex-shrink: 0;
}
.pgc-score-bar-track {
  flex: 1;
  height: 16rpx;
  background: rgba(56, 184, 232, 0.08);
  border-radius: 8rpx;
  overflow: hidden;
  margin: 0 12rpx;
}
.pgc-score-bar {
  height: 100%;
  background: var(--color-primary);
  border-radius: 8rpx;
  min-width: 12rpx;
  transition: width 0.5s ease;
}
.pgc-score-val {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-primary);
  width: 40rpx;
  text-align: right;
}

/* PGC 底部 */
.pgc-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed rgba(56, 184, 232, 0.15);
}
.pgc-avg {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-primary);
}
.pgc-action {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

/* ===== 空状态 ===== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}
.empty-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}
.empty-text {
  font-size: 28rpx;
  color: var(--color-placeholder);
}
