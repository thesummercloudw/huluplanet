<view class="container health-hub">
  <!-- 磨砂噪点纹理层 -->
  <view class="grain-overlay"></view>

  <view class="hub-header">
    <text class="hub-title">健康管理</text>
    <text class="hub-subtitle">选择记录类型</text>
  </view>

  <!-- 选猫 -->
  <view class="hub-cat-section" wx:if="{{cats.length > 1}}">
    <scroll-view class="cat-picker" scroll-x>
      <view class="cat-chip {{selectedCatId === item.catId ? 'active' : ''}}"
            wx:for="{{cats}}" wx:key="catId"
            bindtap="onCatSelect" data-id="{{item.catId}}">
        <text>{{item.name}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 健康类型卡片 -->
  <view class="hub-cards">
    <view class="hub-card vaccine" bindtap="goPage" data-type="vaccine">
      <image class="hub-card-icon-img" src="/images/icon-health-vaccine.svg" mode="aspectFit"></image>
      <view class="hub-card-body">
        <text class="hub-card-title">疫苗接种</text>
        <text class="hub-card-desc">三联、狂犬疫苗等记录</text>
      </view>
      <text class="hub-card-arrow">›</text>
    </view>
    
    <view class="hub-card deworm" bindtap="goPage" data-type="deworm">
      <image class="hub-card-icon-img" src="/images/icon-health-deworm.svg" mode="aspectFit"></image>
      <view class="hub-card-body">
        <text class="hub-card-title">驱虫记录</text>
        <text class="hub-card-desc">体内、体外驱虫管理</text>
      </view>
      <text class="hub-card-arrow">›</text>
    </view>
    
    <view class="hub-card checkup" bindtap="goPage" data-type="checkup">
      <image class="hub-card-icon-img" src="/images/icon-health-checkup.svg" mode="aspectFit"></image>
      <view class="hub-card-body">
        <text class="hub-card-title">体检记录</text>
        <text class="hub-card-desc">血检、B超、X光等检查</text>
      </view>
      <text class="hub-card-arrow">›</text>
    </view>
    
    <view class="hub-card medicine" bindtap="goPage" data-type="medicine">
      <image class="hub-card-icon-img" src="/images/icon-health-medicine.svg" mode="aspectFit"></image>
      <view class="hub-card-body">
        <text class="hub-card-title">用药记录</text>
        <text class="hub-card-desc">药品、剂量、疗程追踪</text>
      </view>
      <text class="hub-card-arrow">›</text>
    </view>
    
    <view class="hub-card weight" bindtap="goPage" data-type="weight">
      <image class="hub-card-icon-img" src="/images/icon-health-weight.svg" mode="aspectFit"></image>
      <view class="hub-card-body">
        <text class="hub-card-title">体重记录</text>
        <text class="hub-card-desc">体重变化追踪</text>
      </view>
      <text class="hub-card-arrow">›</text>
    </view>
  </view>
</view>
