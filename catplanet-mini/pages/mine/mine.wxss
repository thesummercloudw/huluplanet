.mine-page {
  padding-top: 60rpx;
}

.family-card {
  display: flex;
  flex-direction: column;
}

.family-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.family-name {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.invite-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-bg);
  border-radius: var(--radius-sm);
  padding: 16rpx 24rpx;
}

.invite-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.invite-copy {
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 500;
}

/* 数据概览 */
.stats-card {
  display: flex;
  justify-content: space-around;
  margin-top: 24rpx;
  padding: 32rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.stat-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

/* 功能列表 */
.action-card {
  margin-top: 24rpx;
}

.action-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.action-item:last-child {
  border-bottom: none;
}

.action-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.action-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--color-text);
}

.action-badge {
  background: var(--color-primary);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
}

.action-arrow {
  font-size: 32rpx;
  color: var(--color-text-secondary);
}
