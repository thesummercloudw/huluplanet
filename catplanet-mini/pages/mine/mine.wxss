.mine-page {
  padding-top: 60rpx;
}

/* 用户信息卡片 */
.user-card {
  display: flex;
  align-items: center;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.user-avatar-wrap {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(56, 184, 232, 0.3);
}

.user-avatar-edit-icon {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  width: 40rpx;
  height: 40rpx;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-nickname-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.user-nickname {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text);
}

.user-nickname-edit-icon {
  width: 32rpx;
  height: 32rpx;
  margin-left: 12rpx;
}

.user-family-tag {
  font-size: 24rpx;
  color: var(--color-primary);
  background: rgba(56, 184, 232, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  align-self: flex-start;
}
.family-card {
  display: flex;
  flex-direction: column;
}

.family-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.family-name {
  font-size: 36rpx;
  font-weight: 700;
}

.family-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.family-edit-icon-img {
  width: 32rpx;
  height: 32rpx;
  margin-left: 12rpx;
}

.invite-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-bg);
  border-radius: var(--radius-sm);
  padding: 16rpx 24rpx;
}

.invite-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.invite-copy {
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 500;
}

/* 数据概览 */
.stats-card {
  display: flex;
  justify-content: space-around;
  margin-top: 24rpx;
  padding: 32rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.stat-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

/* 功能列表 */
.action-card {
  margin-top: 24rpx;
}

.action-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.action-item:last-child {
  border-bottom: none;
}

.action-icon-img {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
}

.action-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--color-text);
}

.action-badge {
  background: var(--color-primary);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
}

.action-arrow {
  font-size: 32rpx;
  color: var(--color-text-secondary);
}
