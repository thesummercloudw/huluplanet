<view class="container mine-page">
  <!-- 家庭信息卡片 -->
  <view class="card family-card" wx:if="{{familyName}}">
    <text class="family-label">当前家庭</text>
    <text class="family-name">{{familyName}}</text>
    <view class="invite-row" bindtap="copyInviteCode">
      <text class="invite-label">邀请码：{{inviteCode}}</text>
      <text class="invite-copy">复制</text>
    </view>
  </view>

  <!-- 数据概览 -->
  <view class="card stats-card">
    <view class="stat-item">
      <text class="stat-num">{{catCount}}</text>
      <text class="stat-label">猫咪</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{pendingReminders}}</text>
      <text class="stat-label">待提醒</text>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="card action-card">
    <view class="action-item" bindtap="goReminders">
      <text class="action-icon">🔔</text>
      <text class="action-text">提醒管理</text>
      <text class="action-badge" wx:if="{{pendingReminders > 0}}">{{pendingReminders}}</text>
      <text class="action-arrow">›</text>
    </view>
    <view class="action-item" bindtap="handleLogout">
      <text class="action-icon">🚨</text>
      <text class="action-text">退出登录</text>
      <text class="action-arrow">›</text>
    </view>
  </view>
</view>
