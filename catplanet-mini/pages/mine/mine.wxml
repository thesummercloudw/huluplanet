<view class="container mine-page">
  <view class="card family-card" wx:if="{{familyName}}">
    <text class="family-label">当前家庭</text>
    <text class="family-name">{{familyName}}</text>
    <view class="invite-row" bindtap="copyInviteCode">
      <text class="invite-label">邀请码：{{inviteCode}}</text>
      <text class="invite-copy">复制</text>
    </view>
  </view>

  <view class="card action-card">
    <view class="action-item" bindtap="handleLogout">
      <text class="action-text">退出登录</text>
    </view>
  </view>
</view>
