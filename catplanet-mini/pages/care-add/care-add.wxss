@import '../feeding-add/feeding-add.wxss';

.type-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.type-chip { display: flex; flex-direction: column; align-items: center; padding: 20rpx 24rpx; background: var(--color-card); border-radius: var(--radius-md); border: 2rpx solid transparent; min-width: 140rpx; box-shadow: var(--shadow-card); }
.type-chip.active { background: var(--color-primary-light); border-color: var(--color-accent); }
.type-icon { font-size: 36rpx; margin-bottom: 8rpx; }
.type-label { font-size: 22rpx; color: var(--color-text-secondary); }
.type-chip.active .type-label { color: var(--color-accent); }

.form-textarea { background: var(--color-card); border-radius: var(--radius-md); padding: 24rpx 28rpx; font-size: 28rpx; color: var(--color-text); width: 100%; height: 160rpx; box-sizing: border-box; box-shadow: var(--shadow-card); }
