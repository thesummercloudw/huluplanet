.reminders-page {
  padding-bottom: 40rpx;
}

/* Tab 样式 */
.tab-bar {
  width: 100%;
  display: flex;
  background: #fff;
  border-radius: var(--radius-md);
  padding: 8rpx;
  margin-bottom: 24rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: var(--radius-sm);
  font-size: 26rpx;
  color: var(--color-text-secondary);
  transition: all 0.3s;
}

.tab-item.active {
  background: var(--color-primary);
  color: #fff;
  font-weight: 600;
}

/* 提醒列表 */
.reminder-list {
  width: 100%;
}

.reminder-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  background: #fff;
  border-radius: var(--radius-md);
  margin-bottom: 16rpx;
}

.reminder-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
}

.reminder-body {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.reminder-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
}

.reminder-time {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 6rpx;
}

/* 操作按钮 */
.reminder-actions {
  display: flex;
  gap: 16rpx;
}

.action-done {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
}

.action-cancel {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--color-border);
  color: var(--color-text-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

/* 状态标签 */
.status-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-badge.sent {
  background: #E6F7FF;
  color: #1890FF;
}

.status-badge.done {
  background: #F6FFED;
  color: #52C41A;
}

.status-badge.cancelled {
  background: #F5F5F5;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.loading-state {
  text-align: center;
  padding: 60rpx 0;
  color: var(--color-text-secondary);
  font-size: 26rpx;
}
