.page {
  padding: 24rpx;
  background: transparent;
  min-height: 100vh;
}
.food-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 32rpx;
}
.section {
  background: rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(20px) saturate(1.2);
  -webkit-backdrop-filter: blur(20px) saturate(1.2);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}
.label {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}
.char-count {
  font-weight: 400;
  color: #999;
  font-size: 22rpx;
}

/* Stars */
.stars {
  display: flex;
  gap: 16rpx;
}
.star {
  font-size: 40rpx;
  opacity: 0.3;
}
.star.active {
  opacity: 1;
}

/* Cat list */
.cat-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.cat-chip {
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #666;
  background: #F5F5F5;
  border: 1rpx solid #EEE;
}
.cat-chip.active {
  background: rgba(53, 200, 180, 0.12);
  color: #35C8B4;
  border-color: #35C8B4;
}

/* Textarea */
.input-area {
  width: 100%;
  height: 240rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #333;
}

/* Submit */
.submit-btn {
  background: linear-gradient(135deg, #35C8B4, #A4CF4A);
  color: #FFF;
  text-align: center;
  padding: 24rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-top: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(53, 200, 180, 0.25);
}
