.page {
  padding: 24rpx;
  background: #FFF5F0;
  min-height: 100vh;
}
.food-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 32rpx;
}
.section {
  background: #FFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}
.label {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}
.char-count {
  font-weight: 400;
  color: #999;
  font-size: 22rpx;
}

/* Stars */
.stars {
  display: flex;
  gap: 16rpx;
}
.star {
  font-size: 40rpx;
  opacity: 0.3;
}
.star.active {
  opacity: 1;
}

/* Cat list */
.cat-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.cat-chip {
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #666;
  background: #F5F5F5;
  border: 1rpx solid #EEE;
}
.cat-chip.active {
  background: #FFF0EB;
  color: #FF8C69;
  border-color: #FF8C69;
}

/* Textarea */
.input-area {
  width: 100%;
  height: 240rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #333;
}

/* Submit */
.submit-btn {
  background: #FF8C69;
  color: #FFF;
  text-align: center;
  padding: 24rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-top: 40rpx;
}
