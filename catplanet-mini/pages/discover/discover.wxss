.page {
  padding: 0 24rpx 24rpx;
  background: transparent;
  min-height: 100vh;
}

/* Hospital */
.filter-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}
.filter-item {
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.4);
  color: #666;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}
.filter-item.active {
  background: rgba(53, 200, 180, 0.15);
  color: #35C8B4;
  font-weight: 600;
  border-color: rgba(53, 200, 180, 0.3);
}

.hospital-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(53, 200, 180, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}
.hospital-info {
  flex: 1;
}
.hospital-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.type-badge {
  display: inline-block;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 8rpx;
  flex-shrink: 0;
}
.badge-hospital {
  background: rgba(255, 107, 107, 0.15);
  color: #FF6B6B;
}
.badge-store {
  background: rgba(53, 200, 180, 0.15);
  color: #35C8B4;
}
.hospital-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A6B5A;
}
.hospital-address {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}
.hospital-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #999;
}
.hospital-score {
  color: #35C8B4;
  font-weight: 600;
}
.hospital-distance {
  color: #FF9843;
  font-weight: 500;
}
.hospital-tags {
  display: flex;
  gap: 8rpx;
  margin-top: 10rpx;
  flex-wrap: wrap;
}
.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background: rgba(53, 200, 180, 0.1);
  color: #35C8B4;
  border-radius: 8rpx;
}
.nav-btn {
  padding: 12rpx 24rpx;
  background: rgba(53, 200, 180, 0.12);
  color: #35C8B4;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 20rpx;
  flex-shrink: 0;
}

/* Empty */
.empty {
  text-align: center;
  color: #999;
  padding: 80rpx 0;
  font-size: 28rpx;
}
