.page {
  padding: 0 24rpx 24rpx;
  background: transparent;
  min-height: 100vh;
}

/* Segment */
.segment {
  display: flex;
  background: rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-radius: 32rpx;
  margin: 24rpx 0;
  padding: 6rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}
.seg-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #666;
}
.seg-item.active {
  background: #35C8B4;
  color: #FFF;
  font-weight: 600;
}

/* Hospital */
.hospital-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(53, 200, 180, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}
.hospital-info {
  flex: 1;
}
.hospital-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A6B5A;
}
.hospital-address {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}
.hospital-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #999;
}
.hospital-score {
  color: #35C8B4;
  font-weight: 600;
}
.hospital-tags {
  display: flex;
  gap: 8rpx;
  margin-top: 10rpx;
  flex-wrap: wrap;
}
.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background: rgba(53, 200, 180, 0.1);
  color: #35C8B4;
  border-radius: 8rpx;
}
.nav-btn {
  padding: 12rpx 24rpx;
  background: rgba(53, 200, 180, 0.12);
  color: #35C8B4;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 20rpx;
  flex-shrink: 0;
}

/* Adoption Grid */
.adopt-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
.adopt-card {
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(53, 200, 180, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}
.adopt-cover {
  width: 100%;
  height: 240rpx;
}
.adopt-info {
  padding: 16rpx;
}
.adopt-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A6B5A;
}
.adopt-meta {
  display: flex;
  gap: 12rpx;
  font-size: 22rpx;
  color: #666;
  margin-top: 6rpx;
}
.adopt-city {
  font-size: 20rpx;
  color: #999;
  margin-top: 6rpx;
}

/* Empty */
.empty {
  text-align: center;
  color: #999;
  padding: 80rpx 0;
  font-size: 28rpx;
}
