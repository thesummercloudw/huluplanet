/* 猫咪筛选栏 */
.cat-filter {
  white-space: nowrap;
  margin-bottom: 20rpx;
  padding: 4rpx 0;
}

.cat-chip {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  background: rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(36px) saturate(1.35);
  -webkit-backdrop-filter: blur(36px) saturate(1.35);
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  transition: all 0.3s;
}

.cat-chip.active {
  background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
  color: #fff;
  font-weight: 600;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(53, 200, 180, 0.3);
}

/* Tab 切换栏 */
.tab-bar {
  display: flex;
  background: rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(36px) saturate(1.35);
  -webkit-backdrop-filter: blur(36px) saturate(1.35);
  border-radius: var(--radius-lg);
  padding: 8rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  border-radius: var(--radius-md);
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(53, 200, 180, 0.3);
}

/* 记录列表 */
.record-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(36px) saturate(1.35);
  -webkit-backdrop-filter: blur(36px) saturate(1.35);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: var(--shadow-card);
}

.record-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
  width: 56rpx;
  text-align: center;
}

.record-info {
  flex: 1;
}

.record-main {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.record-food {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}

.record-tag {
  font-size: 20rpx;
  background: rgba(53, 200, 180, 0.12);
  color: var(--color-primary);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.record-sub {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.record-amount {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.record-time {
  font-size: 22rpx;
  color: var(--color-placeholder);
}

.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: var(--color-placeholder);
  font-size: 28rpx;
}

/* 统计区域 */
.days-filter {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.day-btn {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  background: rgba(255, 255, 255, 0.4);
  border-radius: var(--radius-sm);
  border: 1rpx solid var(--color-border);
}

.day-btn.active {
  background: var(--color-primary);
  color: #fff;
  border-color: var(--color-primary);
}

.summary-card {
  display: flex;
  background: rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(36px) saturate(1.35);
  -webkit-backdrop-filter: blur(36px) saturate(1.35);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: var(--shadow-card);
}

.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-value {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.summary-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

/* 图表卡片 */
.chart-card {
  background: rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(36px) saturate(1.35);
  -webkit-backdrop-filter: blur(36px) saturate(1.35);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: var(--shadow-card);
}

.chart-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 24rpx;
}

/* 柱状图 */
.bar-chart {
  display: flex;
  align-items: flex-end;
  height: 240rpx;
  gap: 8rpx;
  padding-top: 32rpx;
}

.bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
  position: relative;
}

.bar-fill {
  position: absolute;
  bottom: 36rpx;
  left: 20%;
  right: 20%;
  background: linear-gradient(to top, var(--color-primary), var(--color-accent));
  border-radius: 6rpx 6rpx 0 0;
  min-height: 4rpx;
  transition: height 0.3s;
}

.bar-value {
  position: absolute;
  bottom: calc(100% - 24rpx);
  font-size: 18rpx;
  color: var(--color-primary);
  font-weight: 500;
  white-space: nowrap;
}

.bar-label {
  position: absolute;
  bottom: 0;
  font-size: 18rpx;
  color: var(--color-placeholder);
  white-space: nowrap;
}

/* 类型分布 */
.type-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.type-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.type-name {
  font-size: 24rpx;
  color: var(--color-text);
  width: 80rpx;
}

.type-bar-wrap {
  flex: 1;
  height: 24rpx;
  background: rgba(53, 200, 180, 0.1);
  border-radius: 12rpx;
  overflow: hidden;
}

.type-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
  border-radius: 12rpx;
  min-width: 8rpx;
  transition: width 0.3s;
}

.type-count {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  width: 60rpx;
  text-align: right;
}

/* FAB 按钮 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
  color: #fff;
  padding: 20rpx 36rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(53, 200, 180, 0.35);
}
