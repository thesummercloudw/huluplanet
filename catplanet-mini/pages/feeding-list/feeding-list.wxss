/* 猫咪筛选栏 */
.cat-filter {
  white-space: nowrap;
  margin-bottom: 20rpx;
  padding: 4rpx 0;
}

.cat-chip {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  background: rgba(255, 255, 255, 0.72);
  border-radius: 32rpx;
  border: 1.5rpx solid rgba(0, 0, 0, 0.06);
  transition: all 0.3s;
}

.cat-chip.active {
  background: var(--color-primary);
  color: #fff;
  font-weight: 600;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(56, 184, 232, 0.3);
}

/* Tab 切换栏 */
.tab-bar {
  display: flex;
  background: rgba(255, 255, 255, 0.72);
  border-radius: var(--radius-lg);
  padding: 8rpx;
  margin-bottom: 24rpx;
  border: 1.5rpx solid rgba(0, 0, 0, 0.06);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  border-radius: var(--radius-md);
  transition: all 0.3s;
}

.tab-item.active {
  background: var(--color-primary);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(56, 184, 232, 0.3);
}

/* 记录列表 */
.record-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.72);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1.5rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: var(--shadow-card);
}

.record-icon {
  margin-right: 20rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.record-icon-img {
  width: 48rpx;
  height: 48rpx;
}

.record-info {
  flex: 1;
}

.record-main {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.record-food {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}

.record-tag {
  font-size: 20rpx;
  background: rgba(56, 184, 232, 0.12);
  color: var(--color-primary);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.record-sub {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.record-amount {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.record-time {
  font-size: 22rpx;
  color: var(--color-placeholder);
}

.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: var(--color-placeholder);
  font-size: 28rpx;
}

/* 统计区域 */
.days-filter {
  display: flex;
  gap: 12rpx;
  margin-bottom: 28rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 40rpx;
  padding: 8rpx;
  border: 2rpx dashed rgba(56, 184, 232, 0.3);
}

.day-btn {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  background: transparent;
  border-radius: 32rpx;
  border: none;
  font-weight: 500;
  transition: all 0.3s;
}

.day-btn.active {
  background: var(--color-primary);
  color: #fff;
  border-color: transparent;
  box-shadow: 0 4rpx 14rpx rgba(56, 184, 232, 0.35);
  transform: scale(1.02);
}

/* 汇总卡片 - 手绘风 */
.summary-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.82);
  border-radius: var(--radius-lg);
  padding: 36rpx 28rpx;
  margin-bottom: 28rpx;
  border: 2rpx solid rgba(42, 42, 42, 0.08);
  box-shadow: var(--shadow-card);
  position: relative;
  overflow: hidden;
}

.summary-card::before {
  content: '';
  position: absolute;
  top: -20rpx;
  right: -20rpx;
  width: 80rpx;
  height: 80rpx;
  background: rgba(56, 184, 232, 0.06);
  border-radius: 50%;
}

.summary-card::after {
  content: '';
  position: absolute;
  bottom: -10rpx;
  left: 40rpx;
  width: 50rpx;
  height: 50rpx;
  background: rgba(142, 189, 60, 0.06);
  border-radius: 50%;
}

.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.summary-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.summary-icon-wrap.blue {
  background: rgba(56, 184, 232, 0.12);
}

.summary-icon-wrap.green {
  background: rgba(142, 189, 60, 0.12);
}

.summary-icon-wrap.pink {
  background: rgba(255, 184, 198, 0.18);
}

.summary-icon {
  width: 36rpx;
  height: 36rpx;
}

.summary-divider {
  width: 2rpx;
  height: 72rpx;
  background: linear-gradient(to bottom, transparent, rgba(42, 42, 42, 0.08), transparent);
}

.summary-value {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-text);
  letter-spacing: -1rpx;
}

.summary-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

/* 图表卡片 - 手绘风 */
.chart-card {
  background: rgba(255, 255, 255, 0.82);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  margin-bottom: 28rpx;
  border: 2rpx solid rgba(42, 42, 42, 0.08);
  box-shadow: var(--shadow-card);
  position: relative;
}

.chart-card::after {
  content: '';
  position: absolute;
  bottom: 12rpx;
  right: 16rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(142, 189, 60, 0.06);
}

.chart-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 24rpx;
}

.chart-title-icon {
  width: 36rpx;
  height: 36rpx;
}

.chart-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
}

/* 柱状图 - 手绘风 */
.bar-chart {
  display: flex;
  align-items: flex-end;
  height: 260rpx;
  gap: 8rpx;
  padding-top: 36rpx;
  border-bottom: 2rpx dashed rgba(42, 42, 42, 0.08);
  padding-bottom: 40rpx;
}

.bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
  position: relative;
}

.bar-fill {
  position: absolute;
  bottom: 0;
  left: 18%;
  right: 18%;
  background: var(--color-primary);
  border-radius: 8rpx 8rpx 4rpx 4rpx;
  min-height: 6rpx;
  transition: height 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  opacity: 0.85;
}

.bar-value {
  position: absolute;
  top: -36rpx;
  font-size: 18rpx;
  color: var(--color-primary);
  font-weight: 600;
  white-space: nowrap;
}

.bar-label {
  position: absolute;
  bottom: -36rpx;
  font-size: 18rpx;
  color: var(--color-placeholder);
  white-space: nowrap;
}

/* 类型分布 - 手绘风 */
.type-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.type-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.type-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--color-primary);
  flex-shrink: 0;
  opacity: 0.8;
}

.type-dot.pink {
  background: #FFB8C6;
}

.type-name {
  font-size: 24rpx;
  color: var(--color-text);
  width: 90rpx;
  font-weight: 500;
}

.type-bar-wrap {
  flex: 1;
  height: 26rpx;
  background: rgba(56, 184, 232, 0.08);
  border-radius: 13rpx;
  overflow: hidden;
}

.type-bar {
  height: 100%;
  background: var(--color-primary);
  border-radius: 13rpx;
  min-width: 10rpx;
  transition: width 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  opacity: 0.75;
}

.type-count {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  width: 60rpx;
  text-align: right;
  font-weight: 500;
}

/* FAB 按钮 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  background: var(--color-primary);
  color: #fff;
  padding: 20rpx 36rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(56, 184, 232, 0.35);
}
