<view class="container detail-page" wx:if="{{cat}}">
  <!-- 头像 -->
  <view class="detail-avatar-wrap">
    <image class="detail-avatar" src="{{cat.avatar || 'data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIxMjgiIGhlaWdodD0iMTI4IiB2aWV3Qm94PSIwIDAgMTI4IDEyOCI+PGNpcmNsZSBjeD0iNjQiIGN5PSI2NCIgcj0iNjQiIGZpbGw9IiNmNWY1ZjUiLz48dGV4dCB4PSI2NCIgeT0iNzYiIGZvbnQtc2l6ZT0iNTYiIHRleHQtYW5jaG9yPSJtaWRkbGUiPvCfkLA8L3RleHQ+PC9zdmc+'}}" mode="aspectFill"/>
  </view>

  <text class="detail-name">{{cat.name}}</text>

  <!-- Tab 切换 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'info' ? 'active' : ''}}" bindtap="switchTab" data-tab="info">
      <text>基本信息</text>
    </view>
    <view class="tab-item {{activeTab === 'records' ? 'active' : ''}}" bindtap="switchTab" data-tab="records">
      <text>养护记录</text>
    </view>
  </view>

  <!-- 基本信息 Tab -->
  <view class="tab-content" wx:if="{{activeTab === 'info'}}">
    <view class="card info-card">
      <view class="info-row">
        <text class="info-label">品种</text>
        <text class="info-value">{{cat.breed || '未知'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">性别</text>
        <text class="info-value">{{cat.gender === 'male' ? '♂ 弟弟' : cat.gender === 'female' ? '♀ 妹妹' : '未知'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">生日</text>
        <text class="info-value">{{cat.birthday || '未设置'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">体重</text>
        <text class="info-value">{{cat.weightKg ? cat.weightKg + ' kg' : '未记录'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">是否绝育</text>
        <text class="info-value">{{cat.isNeutered ? '已绝育' : '未绝育'}}</text>
      </view>
      <view class="info-row" wx:if="{{cat.adoptionDate}}">
        <text class="info-label">到家日</text>
        <text class="info-value">{{cat.adoptionDate}}</text>
      </view>
    </view>

    <!-- 性格标签 -->
    <view class="tags-section" wx:if="{{cat.personalityTags && cat.personalityTags.length > 0}}">
      <text class="section-title">性格标签</text>
      <view class="tags-wrap">
        <text class="tag" wx:for="{{cat.personalityTags}}" wx:key="*this">{{item}}</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-bar">
      <button class="btn-primary" bindtap="goEdit">编辑</button>
      <button class="btn-danger" bindtap="handleDelete">移除</button>
    </view>
  </view>

  <!-- 养护记录 Tab -->
  <view class="tab-content" wx:if="{{activeTab === 'records'}}">
    <!-- 快捷添加 -->
    <view class="record-actions">
      <view class="record-action-btn" bindtap="goAddFeeding">
        <text class="action-icon">🍗</text>
        <text class="action-text">喂食</text>
      </view>
      <view class="record-action-btn" bindtap="goAddCare">
        <text class="action-icon">✨</text>
        <text class="action-text">养护</text>
      </view>
      <view class="record-action-btn" bindtap="goAddHealth">
        <text class="action-icon">💊</text>
        <text class="action-text">健康</text>
      </view>
    </view>

    <!-- 记录列表 -->
    <view class="record-list" wx:if="{{records.length > 0}}">
      <view class="record-item" wx:for="{{records}}" wx:key="id">
        <view class="record-icon"><image class="record-icon-img" src="{{item.icon}}" mode="aspectFit"></image></view>
        <view class="record-body">
          <text class="record-title">{{item.title}}</text>
          <text class="record-desc" wx:if="{{item.description}}">{{item.description}}</text>
        </view>
        <text class="record-time">{{item.timeText}}</text>
      </view>
    </view>

    <view class="empty-records" wx:elif="{{!recordLoading}}">
      <image class="empty-icon" src="/images/icon-care-other.svg" mode="aspectFit"></image>
      <text class="empty-text">暂无记录，快去添加吧~</text>
    </view>

    <view class="loading-records" wx:if="{{recordLoading}}">
      <text>加载中...</text>
    </view>
  </view>
</view>
