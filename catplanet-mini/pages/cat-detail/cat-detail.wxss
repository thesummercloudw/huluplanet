.detail-page {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-avatar-wrap {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 140, 105, 0.2);
}

.detail-avatar {
  width: 100%;
  height: 100%;
}

.detail-name {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 40rpx;
}

.info-card {
  width: 100%;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  color: var(--color-text-secondary);
  font-size: 28rpx;
}

.info-value {
  font-size: 28rpx;
  font-weight: 500;
}

.tags-section {
  width: 100%;
  margin-top: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  background: var(--color-secondary);
  color: var(--color-primary);
  padding: 8rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
}

.action-bar {
  width: 100%;
  display: flex;
  gap: 24rpx;
  margin-top: 60rpx;
}

.action-bar .btn-primary {
  flex: 1;
}

.btn-danger {
  flex: 1;
  background: #fff;
  color: #FF4D4F;
  border: 2rpx solid #FF4D4F;
  border-radius: var(--radius-md);
  padding: 24rpx 0;
  font-size: 30rpx;
  text-align: center;
}

.btn-danger::after {
  border: none;
}
