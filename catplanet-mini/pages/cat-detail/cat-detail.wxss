.detail-page {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-avatar-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(56, 184, 232, 0.2);
}

.detail-avatar {
  width: 100%;
  height: 100%;
}

.detail-name {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}

/* Tab 样式 */
.tab-bar {
  width: 100%;
  display: flex;
  background: rgba(255, 255, 255, 0.72);
  border-radius: var(--radius-md);
  padding: 8rpx;
  margin-bottom: 24rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  color: var(--color-text-secondary);
  transition: all 0.3s;
}

.tab-item.active {
  background: var(--color-primary);
  color: #fff;
  font-weight: 600;
}

.tab-content {
  width: 100%;
}

.info-card {
  width: 100%;
  padding: 8rpx 32rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.72);
  border-radius: var(--radius-lg);
  border: 1.5rpx solid rgba(0, 0, 0, 0.06);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 16rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  color: var(--color-text-secondary);
  font-size: 28rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  font-weight: 500;
  max-width: 60%;
  text-align: right;
  word-break: break-all;
}

.tags-section {
  width: 100%;
  margin-top: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  background: var(--color-secondary);
  color: var(--color-primary);
  padding: 8rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
}

.action-bar {
  width: 100%;
  display: flex;
  gap: 24rpx;
  margin-top: 60rpx;
}

.action-bar .btn-primary {
  flex: 1;
}

.btn-danger {
  flex: 1;
  background: #fff;
  color: #FF4D4F;
  border: 2rpx solid #FF4D4F;
  border-radius: var(--radius-md);
  padding: 24rpx 0;
  font-size: 30rpx;
  text-align: center;
}

.btn-danger::after {
  border: none;
}

/* 记录 Tab 样式 */
.record-actions {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-bottom: 32rpx;
}

.record-action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.action-icon {
  font-size: 48rpx;
}

.action-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.record-list {
  width: 100%;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.72);
  border-radius: var(--radius-sm);
  margin-bottom: 16rpx;
  border: 1.5rpx solid rgba(0, 0, 0, 0.06);
}

.record-icon {
  margin-right: 20rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.record-icon-img {
  width: 40rpx;
  height: 40rpx;
}

.record-body {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.record-title {
  font-size: 28rpx;
  font-weight: 500;
}

.record-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.record-time {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  white-space: nowrap;
}

.empty-records {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.loading-records {
  text-align: center;
  padding: 40rpx 0;
  color: var(--color-text-secondary);
  font-size: 26rpx;
}
