/* 猫咪详情 - 手绘涂鸦风 */
.detail-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

/* 顶部装饰 + Logo */
.detail-header-top {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.detail-logo {
  width: 72rpx;
  height: 72rpx;
}

.deco-left, .deco-right {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.deco-star {
  font-size: 28rpx;
  color: var(--color-primary);
}
.deco-star.sm {
  font-size: 20rpx;
  color: var(--color-pink);
}

/* 头像 */
.detail-avatar-wrap {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: 20rpx;
  border: 4rpx dashed var(--color-primary);
  box-shadow: 0 8rpx 32rpx rgba(56, 184, 232, 0.18);
}

.detail-avatar {
  width: 100%;
  height: 100%;
}

.detail-name {
  font-size: 42rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.detail-sub {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 28rpx;
  padding: 6rpx 20rpx;
  background: var(--color-primary-light);
  border-radius: 24rpx;
}

/* Tab 样式 */
.tab-bar {
  width: 100%;
  display: flex;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 8rpx;
  margin-bottom: 28rpx;
  border: 1.5rpx solid var(--color-border);
  box-shadow: var(--shadow-card);
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 20rpx 0;
  border-radius: var(--radius-md);
  font-size: 26rpx;
  color: var(--color-text-secondary);
  transition: all 0.3s;
}

.tab-icon {
  width: 28rpx;
  height: 28rpx;
}

.tab-item.active {
  background: var(--color-primary);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(56, 184, 232, 0.25);
}

.tab-content {
  width: 100%;
}

/* 信息卡片 */
.info-card {
  width: 100%;
  padding: 12rpx 32rpx;
  box-sizing: border-box;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  border: 1.5rpx solid var(--color-border);
  box-shadow: var(--shadow-card);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 12rpx;
  border-bottom: 1rpx dashed var(--color-border);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: var(--color-text-secondary);
  font-size: 27rpx;
  flex-shrink: 0;
}

.info-icon {
  width: 32rpx;
  height: 32rpx;
}

.info-value {
  font-size: 28rpx;
  font-weight: 500;
  max-width: 55%;
  text-align: right;
  word-break: break-all;
  color: var(--color-text);
}

.info-value.value-yes {
  color: var(--color-accent);
  font-weight: 600;
}

.info-value.value-no {
  color: var(--color-text-secondary);
}

/* 性格标签 */
.tags-section {
  width: 100%;
  margin-top: 32rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: var(--color-text);
}

.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  background: var(--color-secondary);
  color: var(--color-accent);
  padding: 10rpx 26rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  border: 1.5rpx solid rgba(142, 189, 60, 0.2);
}

/* 操作按钮 */
.action-bar {
  width: 100%;
  display: flex;
  gap: 24rpx;
  margin-top: 60rpx;
}

.btn-edit {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: var(--color-primary) !important;
  color: #fff !important;
  border: none;
  border-radius: var(--radius-md);
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(56, 184, 232, 0.2);
}

.btn-edit::after {
  border: none;
}

.btn-icon {
  width: 32rpx;
  height: 32rpx;
}

.btn-danger {
  flex: 0.6;
  background: #fff !important;
  color: #FF6B6B !important;
  border: 2rpx dashed #FF6B6B;
  border-radius: var(--radius-md);
  padding: 24rpx 0;
  font-size: 28rpx;
  text-align: center;
}

.btn-danger::after {
  border: none;
}

/* 记录 Tab - 快捷操作 */
.record-actions {
  display: flex;
  justify-content: center;
  gap: 56rpx;
  margin-bottom: 36rpx;
  padding: 32rpx 0;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  border: 1.5rpx solid var(--color-border);
  box-shadow: var(--shadow-card);
}

.record-action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.action-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed var(--color-primary);
  transition: all 0.2s;
}

.action-icon-wrap.feeding {
  background: rgba(56, 184, 232, 0.08);
  border-color: var(--color-primary);
}

.action-icon-wrap.care {
  background: rgba(142, 189, 60, 0.08);
  border-color: var(--color-accent);
}

.action-icon-wrap.health {
  background: rgba(255, 184, 198, 0.12);
  border-color: var(--color-pink);
}

.action-icon-img {
  width: 44rpx;
  height: 44rpx;
}

.action-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

/* 记录列表 */
.record-list {
  width: 100%;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  background: var(--color-card);
  border-radius: var(--radius-md);
  margin-bottom: 16rpx;
  border: 1.5rpx solid var(--color-border);
  box-shadow: var(--shadow-card);
}

.record-icon {
  margin-right: 20rpx;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-primary-light);
  border-radius: 50%;
}

.record-icon-img {
  width: 32rpx;
  height: 32rpx;
}

.record-body {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.record-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
}

.record-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 6rpx;
}

.record-time {
  font-size: 22rpx;
  color: var(--color-placeholder);
  white-space: nowrap;
}

/* 空状态 */
.empty-records {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--color-placeholder);
}

/* 加载状态 */
.loading-records {
  text-align: center;
  padding: 40rpx 0;
  color: var(--color-placeholder);
  font-size: 26rpx;
}
