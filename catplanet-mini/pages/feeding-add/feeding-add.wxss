/* 通用表单样式 */
.form-page { padding-bottom: 60rpx; }
.form-title { font-size: 36rpx; font-weight: 700; margin-bottom: 40rpx; color: var(--color-text); }
.form-section { margin-bottom: 36rpx; }
.form-label { font-size: 26rpx; color: var(--color-text-secondary); margin-bottom: 16rpx; }
.form-input { background: var(--color-card); border-radius: var(--radius-md); padding: 24rpx 28rpx; font-size: 28rpx; color: var(--color-text); box-shadow: var(--shadow-card); }

.cat-picker { white-space: nowrap; padding: 8rpx 0; }
.cat-chip { display: inline-block; padding: 14rpx 28rpx; background: var(--color-card); border-radius: var(--radius-md); margin-right: 16rpx; font-size: 26rpx; color: var(--color-text-secondary); border: 2rpx solid transparent; }
.cat-chip.active { background: var(--color-primary-light); border-color: var(--color-accent); color: var(--color-accent); }

.amount-row { display: flex; align-items: center; gap: 16rpx; }
.amount-input { flex: 1; }
.quick-amounts { display: flex; gap: 12rpx; }
.quick-chip { padding: 12rpx 20rpx; background: var(--color-card); border-radius: var(--radius-sm); font-size: 24rpx; color: var(--color-text-secondary); border: 2rpx solid transparent; }
.quick-chip.active { background: var(--color-primary-light); border-color: var(--color-accent); color: var(--color-accent); }

.picker-value { display: flex; justify-content: space-between; align-items: center; }
.picker-arrow { font-size: 20rpx; color: var(--color-text-secondary); }

.form-submit { margin-top: 60rpx; }
.submit-btn { background: var(--color-accent) !important; color: #fff !important; border-radius: var(--radius-md) !important; font-size: 30rpx; padding: 24rpx 0; border: none; }
.submit-btn[disabled] { opacity: 0.6; }
