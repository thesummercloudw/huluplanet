.index-page {
  padding-bottom: 40rpx;
}

/* === 家庭成员区 - 卡片式布局 === */
.family-members-card {
  margin-bottom: 32rpx;
  padding: 24rpx 28rpx 20rpx;
  background: rgba(56, 184, 232, 0.05);
  border-radius: var(--radius-lg);
  border: 1.5rpx solid rgba(56, 184, 232, 0.12);
}

.family-members-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.family-logo {
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
}

.family-members-text {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text);
  letter-spacing: 2rpx;
  flex-shrink: 0;
}

.family-members-header-line {
  flex: 1;
  height: 3rpx;
  background: repeating-linear-gradient(90deg, var(--color-primary) 0, var(--color-primary) 8rpx, transparent 8rpx, transparent 16rpx);
  opacity: 0.3;
  margin-left: 8rpx;
}

.family-members-scroll {
  white-space: nowrap;
}

.family-members-list {
  display: inline-flex;
  align-items: flex-start;
  gap: 32rpx;
  padding: 4rpx 0 8rpx;
}

.member-cat {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.member-cat:active {
  transform: scale(0.92);
}

.member-cat-avatar-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 2.5rpx solid var(--color-primary);
  padding: 3rpx;
  background: #fff;
  box-shadow: 0 3rpx 12rpx rgba(56, 184, 232, 0.15);
  overflow: hidden;
}

.member-cat-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.member-cat-name {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--color-text);
  max-width: 96rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

.member-cat-add-wrap {
  border-style: dashed;
  border-color: rgba(56, 184, 232, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.member-cat-add-icon {
  font-size: 44rpx;
  color: var(--color-primary);
  line-height: 1;
}

/* 快捷记录区 */
.quick-actions {
  background: rgba(56, 184, 232, 0.06);
  border-radius: var(--radius-lg);
  padding: 28rpx 32rpx;
  margin-bottom: 32rpx;
  border: 1.5rpx solid rgba(56, 184, 232, 0.15);
  box-shadow: var(--shadow-card);
}

.quick-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 24rpx;
}

.quick-grid {
  display: flex;
  justify-content: space-around;
  align-items: flex-start;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.quick-icon {
  font-size: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  margin-bottom: 8rpx;
}

.quick-img-icon {
  width: 52rpx;
  height: 52rpx;
  margin-bottom: 6rpx;
}

.quick-cat-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
}

.quick-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.quick-links {
  display: flex;
  justify-content: space-around;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(56, 184, 232, 0.12);
}

.quick-link {
  font-size: 22rpx;
  color: var(--color-primary);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(56, 184, 232, 0.08);
}

/* === 家庭手账 · Journal Style === */
.journal-section {
  margin-top: 8rpx;
  margin-bottom: 32rpx;
}

.journal-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  gap: 10rpx;
}

.journal-header-icon {
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
  transform: rotate(-5deg);
}

.journal-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
  letter-spacing: 2rpx;
}

.journal-header-line {
  flex: 1;
  height: 3rpx;
  background: repeating-linear-gradient(90deg, var(--color-primary) 0, var(--color-primary) 8rpx, transparent 8rpx, transparent 16rpx);
  opacity: 0.4;
  margin: 0 8rpx;
}

.journal-header-deco2 {
  font-size: 26rpx;
  color: var(--color-pink);
  transform: rotate(12deg);
}

/* 日期分组贴纸 */
.journal-date-tag {
  display: inline-flex;
  align-items: center;
  position: relative;
  margin-bottom: 16rpx;
  margin-left: 8rpx;
}

.journal-date-tape {
  position: absolute;
  left: -12rpx;
  top: 50%;
  transform: translateY(-50%) rotate(-3deg);
  width: 48rpx;
  height: 20rpx;
  background: rgba(56, 184, 232, 0.25);
  border-radius: 4rpx;
}

.journal-date-text {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-primary);
  padding: 6rpx 20rpx 6rpx 44rpx;
  background: rgba(56, 184, 232, 0.08);
  border-radius: 0 16rpx 16rpx 0;
  border-left: 3rpx solid var(--color-primary);
}

/* 卡片组 */
.journal-cards {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

/* 单张手账卡片 */
.journal-card {
  position: relative;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx 24rpx 16rpx;
  border: 1.5rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: 2rpx 3rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.2s;
}

.journal-card:nth-child(odd) {
  transform: rotate(-0.6deg);
}

.journal-card:nth-child(even) {
  transform: rotate(0.4deg);
}

.journal-card:nth-child(3n) {
  transform: rotate(-0.3deg);
}

/* 类型色带（左侧边框） */
.journal-card-blue {
  border-left: 5rpx solid #38B8E8;
}

.journal-card-green {
  border-left: 5rpx solid #8EBD3C;
}

.journal-card-pink {
  border-left: 5rpx solid #FFB8C6;
}

/* 图钉装饰 */
.journal-card-pin {
  position: absolute;
  top: -6rpx;
  right: 24rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--color-primary);
  border: 2rpx solid #fff;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.15);
}

/* 卡片顶部 */
.journal-card-top {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.journal-emoji {
  font-size: 32rpx;
}

.journal-emoji-img {
  width: 36rpx;
  height: 36rpx;
}

.journal-badge {
  font-size: 20rpx;
  font-weight: 600;
  padding: 2rpx 14rpx;
  border-radius: 12rpx;
  line-height: 1.6;
}

.journal-badge-blue {
  background: rgba(56, 184, 232, 0.12);
  color: #38B8E8;
}

.journal-badge-green {
  background: rgba(142, 189, 60, 0.12);
  color: #6B9A2A;
}

.journal-badge-pink {
  background: rgba(255, 184, 198, 0.18);
  color: #D4708A;
}

.journal-hour {
  font-size: 22rpx;
  color: var(--color-placeholder);
  margin-left: auto;
  font-variant-numeric: tabular-nums;
}

/* 卡片内容 */
.journal-card-body {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  margin-bottom: 6rpx;
}

.journal-cat-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  flex-shrink: 0;
}

.journal-summary {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 卡片底部 */
.journal-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.journal-time-ago {
  font-size: 20rpx;
  color: var(--color-placeholder);
}

.journal-card-doodle {
  font-size: 20rpx;
  color: var(--color-primary);
  opacity: 0.35;
  letter-spacing: 4rpx;
}

/* 展开收起按钮 */
.journal-toggle {
  display: flex;
  justify-content: center;
  padding: 12rpx 0 4rpx;
}

.journal-toggle-text {
  font-size: 24rpx;
  color: var(--color-primary);
  padding: 10rpx 32rpx;
  border-radius: 24rpx;
  background: rgba(56, 184, 232, 0.08);
  border: 1.5rpx dashed rgba(56, 184, 232, 0.3);
  letter-spacing: 1rpx;
}

/* 猫咪出没 */
.sighting-section {
  margin-bottom: 32rpx;
}

.sighting-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.sighting-add-btn {
  font-size: 24rpx;
  color: #38B8E8;
  background: rgba(56, 184, 232, 0.08);
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(56, 184, 232, 0.25);
}

.sighting-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.sighting-item {
  width: calc(50% - 8rpx);
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border: none;
}

.sighting-img {
  width: 100%;
  height: 200rpx;
}

.sighting-info {
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.sighting-publisher {
  margin-bottom: 2rpx;
}

.sighting-publisher-name {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--color-primary);
}

.sighting-address {
  font-size: 22rpx;
  color: var(--color-text);
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: flex;
  align-items: center;
}

.sighting-content {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sighting-time {
  font-size: 20rpx;
  color: var(--color-placeholder);
}

.sighting-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.sighting-comment-wrap {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.sighting-comment-icon {
  width: 28rpx;
  height: 28rpx;
  vertical-align: middle;
}

.sighting-comment-count {
  font-size: 20rpx;
  color: var(--color-placeholder);
}

.sighting-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
}

.sighting-empty-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.sighting-empty-sub {
  font-size: 22rpx;
  color: var(--color-placeholder);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 160rpx;
}

.empty-emoji {
  font-size: 100rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 40rpx;
}

.empty-btn {
  padding: 18rpx 56rpx;
  background: #38B8E8;
  color: #fff;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(56, 184, 232, 0.2);
  text-align: center;
}
