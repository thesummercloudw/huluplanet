.index-page {
  padding-bottom: 40rpx;
}

.planet-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.planet-logo {
  width: 64rpx;
  height: 64rpx;
  margin-right: 16rpx;
}

.planet-name {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text);
}

/* 猫咪横向滚动 */
.cat-scroll {
  white-space: nowrap;
  margin-bottom: 32rpx;
  padding-bottom: 8rpx;
}

.cat-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(20px) saturate(1.2);
  -webkit-backdrop-filter: blur(20px) saturate(1.2);
  border-radius: var(--radius-lg);
  padding: 24rpx 28rpx;
  box-shadow: var(--shadow-card), inset 0 1rpx 0 rgba(255,255,255,0.5);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  margin-right: 20rpx;
  width: 160rpx;
}

.cat-card-add {
  border: 2rpx dashed rgba(53, 200, 180, 0.35);
  background: rgba(255, 255, 255, 0.25);
  box-shadow: none;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.cat-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-bottom: 12rpx;
}

.add-icon {
  font-size: 48rpx;
  color: var(--color-text-secondary);
  height: 96rpx;
  line-height: 96rpx;
  margin-bottom: 12rpx;
}

.cat-name {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 140rpx;
}

/* 快捷记录区 */
.quick-actions {
  background: rgba(53, 200, 180, 0.12);
  backdrop-filter: blur(24px) saturate(1.1);
  -webkit-backdrop-filter: blur(24px) saturate(1.1);
  border-radius: var(--radius-lg);
  padding: 28rpx 32rpx;
  margin-bottom: 32rpx;
  border: 1rpx solid rgba(53, 200, 180, 0.18);
  box-shadow: var(--shadow-card), inset 0 1rpx 0 rgba(255,255,255,0.3);
}

.quick-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 24rpx;
}

.quick-grid {
  display: flex;
  justify-content: space-around;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.quick-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.quick-cat-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
}

.quick-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

/* Timeline */
.timeline-section {
  margin-top: 8rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 20rpx;
}

.timeline-list {
  padding-left: 24rpx;
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 28rpx;
  position: relative;
  padding-left: 28rpx;
}

.timeline-dot {
  position: absolute;
  left: 0;
  top: 12rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--color-border);
}

.timeline-dot.feeding {
  background: #35C8B4;
}

.timeline-dot.care {
  background: #A4CF4A;
}

.timeline-dot.health {
  background: #FFB8C6;
}

.timeline-content {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 8rpx;
}

.timeline-cat {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
}

.timeline-summary {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.timeline-time {
  font-size: 22rpx;
  color: var(--color-placeholder);
  margin-left: auto;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 160rpx;
}

.empty-emoji {
  font-size: 100rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 40rpx;
}

.empty-btn {
  padding: 18rpx 56rpx;
  background: linear-gradient(135deg, #35C8B4, #A4CF4A);
  color: #fff;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(53, 200, 180, 0.25);
}
