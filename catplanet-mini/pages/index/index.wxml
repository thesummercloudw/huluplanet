<view class="container index-page">
  <!-- 磨砂噪点纹理层 -->
  <view class="grain-overlay"></view>

  <!-- 顶部星球头 -->
  <view class="planet-header">
    <image class="planet-logo" src="/images/logo.svg" mode="aspectFit"></image>
    <text class="planet-name">{{familyName || '我的星球'}}</text>
  </view>

  <!-- 猫咪卡片轮播 -->
  <scroll-view class="cat-scroll" scroll-x wx:if="{{cats.length > 0}}">
    <view class="cat-card" wx:for="{{cats}}" wx:key="catId" bindtap="goCatDetail" data-id="{{item.catId}}">
      <image class="cat-avatar" src="{{item.avatar || 'data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIxMjgiIGhlaWdodD0iMTI4IiB2aWV3Qm94PSIwIDAgMTI4IDEyOCI+PGNpcmNsZSBjeD0iNjQiIGN5PSI2NCIgcj0iNjQiIGZpbGw9IiNmNWY1ZjUiLz48dGV4dCB4PSI2NCIgeT0iNzYiIGZvbnQtc2l6ZT0iNTYiIHRleHQtYW5jaG9yPSJtaWRkbGUiPvCfkLA8L3RleHQ+PC9zdmc+'}}" mode="aspectFill"/>
      <text class="cat-name">{{item.name}}</text>
    </view>

  </scroll-view>

  <!-- 快捷记录区 -->
  <view class="quick-actions">
    <view class="quick-title">快捷记录</view>
    <view class="quick-grid">
      <view class="quick-item" bindtap="goFeeding">
        <text class="quick-icon">🍗</text>
        <text class="quick-label">喂食</text>
      </view>
      <view class="quick-item" bindtap="goCare">
        <text class="quick-icon">🧹</text>
        <text class="quick-label">养护</text>
      </view>
      <view class="quick-item" bindtap="goHealth">
        <text class="quick-icon">💉</text>
        <text class="quick-label">健康</text>
      </view>
      <view class="quick-item" bindtap="goAddCat">
        <image class="quick-cat-icon" src="/images/cat-icon.svg" mode="aspectFit"></image>
        <text class="quick-label">添加猫咪</text>
      </view>
    </view>
  </view>

  <!-- 家庭动态 Timeline -->
  <view class="timeline-section" wx:if="{{timeline.length > 0}}">
    <view class="section-title">家庭动态</view>
    <view class="timeline-list">
      <view class="timeline-item" wx:for="{{timeline}}" wx:key="recordId">
        <view class="timeline-dot {{item.type}}"></view>
        <view class="timeline-content">
          <text class="timeline-cat">{{item.catName}}</text>
          <text class="timeline-summary">{{item.summary}}</text>
          <text class="timeline-time">{{item.timeStr}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{cats.length === 0 && !loading}}">
    <text class="empty-emoji">😺</text>
    <text class="empty-text">还没有猫咪入住星球</text>
    <text class="empty-sub">点击下方按钮添加第一只喵</text>
    <view class="empty-btn" bindtap="goAddCat">添加猫咪</view>
  </view>
</view>
