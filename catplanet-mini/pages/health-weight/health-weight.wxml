<view class="container form-page">
  <view class="grain-overlay"></view>
  <view class="form-title"><image class="form-title-icon" src="/images/icon-health-weight.svg" mode="aspectFit"></image> 体重记录</view>

  <!-- 选猫 -->
  <view class="form-section">
    <view class="form-label">选择猫咪</view>
    <scroll-view class="cat-picker" scroll-x>
      <view class="cat-chip {{selectedCatId === item.catId ? 'active' : ''}}"
            wx:for="{{cats}}" wx:key="catId"
            bindtap="onCatSelect" data-id="{{item.catId}}">
        <text>{{item.name}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 体重 -->
  <view class="form-section">
    <view class="form-label">体重 (kg)</view>
    <view class="weight-input-area">
      <input class="form-input weight-big-input" type="digit" placeholder="4.5"
             value="{{weight}}" bindinput="onWeightInput" focus="{{true}}"/>
      <text class="weight-unit">kg</text>
    </view>
  </view>

  <!-- 日期 -->
  <view class="form-section">
    <view class="form-label">称重日期</view>
    <picker mode="date" value="{{recordDate}}" bindchange="onDateChange">
      <view class="form-input picker-value">
        {{recordDate || '选择日期'}}
        <text class="picker-arrow">▼</text>
      </view>
    </picker>
  </view>

  <!-- 备注 -->
  <view class="form-section">
    <view class="form-label">备注 <text class="label-hint">(可选)</text></view>
    <textarea class="form-textarea" placeholder="饮食变化、身体状态等..."
              value="{{note}}" bindinput="onNoteInput" maxlength="200"/>
  </view>

  <!-- 提交 -->
  <view class="form-submit">
    <button class="submit-btn" bindtap="onSubmit" disabled="{{submitting}}">
      {{submitting ? '提交中...' : '记录完成'}}
    </button>
  </view>
</view>
