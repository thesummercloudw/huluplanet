.page { background: transparent; min-height: 100vh; padding-bottom: 120rpx; }
.cover-swiper { width: 100%; height: 500rpx; }
.cover-img { width: 100%; height: 500rpx; }

.info-card { background: rgba(255, 255, 255, 0.72); padding: 24rpx; margin: -40rpx 24rpx 20rpx; border-radius: 16rpx; position: relative; z-index: 1; box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04); border: 1.5rpx solid rgba(0, 0, 0, 0.06); }
.cat-name { font-size: 36rpx; font-weight: 700; color: #333; }
.cat-meta { display: flex; gap: 16rpx; font-size: 24rpx; color: #666; margin-top: 10rpx; }
.cat-city { font-size: 22rpx; color: #999; margin-top: 8rpx; display: flex; align-items: center; }
.cat-personality { font-size: 24rpx; color: #666; margin-top: 12rpx; line-height: 1.5; }

.section { background: rgba(255, 255, 255, 0.72); border-radius: 16rpx; padding: 24rpx; margin: 0 24rpx 20rpx; border: 1.5rpx solid rgba(0, 0, 0, 0.06); }
.section-title { font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 12rpx; }
.section-text { font-size: 26rpx; color: #666; line-height: 1.6; }
.health-items { display: flex; flex-direction: column; gap: 10rpx; }
.health-item { font-size: 24rpx; color: #666; }

.apply-btn { position: fixed; bottom: 40rpx; left: 50%; transform: translateX(-50%); background: #38B8E8; color: #FFF; font-size: 30rpx; font-weight: 600; padding: 24rpx 80rpx; border-radius: 40rpx; box-shadow: 0 8rpx 24rpx rgba(56, 184, 232, 0.3); }

.apply-form { margin: 0 24rpx; background: rgba(255, 255, 255, 0.72); border-radius: 16rpx; padding: 24rpx; border: 1.5rpx solid rgba(0, 0, 0, 0.06); }
.form-title { font-size: 30rpx; font-weight: 700; color: #333; margin-bottom: 20rpx; }
.form-item { margin-bottom: 20rpx; }
.form-label { font-size: 24rpx; font-weight: 600; color: #333; margin-bottom: 10rpx; }
.form-textarea { width: 100%; height: 160rpx; font-size: 26rpx; color: #333; background: #F9F9F9; border-radius: 12rpx; padding: 16rpx; box-sizing: border-box; }

.commitment { display: flex; align-items: flex-start; gap: 12rpx; }
.checkbox { width: 40rpx; height: 40rpx; border: 2rpx solid #DDD; border-radius: 8rpx; text-align: center; line-height: 40rpx; font-size: 24rpx; color: transparent; flex-shrink: 0; }
.checkbox.checked { background: #38B8E8; border-color: #38B8E8; color: #FFF; }
.commitment-text { font-size: 22rpx; color: #666; line-height: 1.5; flex: 1; }

.form-actions { display: flex; gap: 16rpx; margin-top: 24rpx; }
.cancel-btn { flex: 1; text-align: center; padding: 20rpx; border-radius: 32rpx; font-size: 26rpx; color: #999; background: #F5F5F5; }
.submit-btn { flex: 1; text-align: center; padding: 20rpx; border-radius: 32rpx; font-size: 26rpx; font-weight: 600; color: #FFF; background: #38B8E8; }
