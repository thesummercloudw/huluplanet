<view class="container form-page">
  <view class="grain-overlay"></view>
  <view class="form-title"><image class="form-title-icon" src="/images/icon-health-checkup.svg" mode="aspectFit"></image> 体检记录</view>

  <!-- 选猫 -->
  <view class="form-section">
    <view class="form-label">选择猫咪</view>
    <scroll-view class="cat-picker" scroll-x>
      <view class="cat-chip {{selectedCatId === item.catId ? 'active' : ''}}"
            wx:for="{{cats}}" wx:key="catId"
            bindtap="onCatSelect" data-id="{{item.catId}}">
        <text>{{item.name}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 检查项目多选 -->
  <view class="form-section">
    <view class="form-label">检查项目 <text class="label-hint">(可多选)</text></view>
    <view class="chip-grid">
      <view class="multi-chip {{item.checked ? 'active' : ''}}"
            wx:for="{{checkItems}}" wx:key="value"
            bindtap="onCheckItemToggle" data-index="{{index}}">
        {{item.label}}
      </view>
    </view>
    <input class="form-input mt-16" placeholder="其他检查项目"
           value="{{customItem}}" bindinput="onCustomItemInput"
           bindconfirm="onCustomItemAdd"/>
  </view>

  <!-- 体检日期 -->
  <view class="form-section">
    <view class="form-label">体检日期</view>
    <picker mode="date" value="{{recordDate}}" bindchange="onDateChange">
      <view class="form-input picker-value">
        {{recordDate || '选择日期'}}
        <text class="picker-arrow">▼</text>
      </view>
    </picker>
  </view>

  <!-- 检查结果 -->
  <view class="form-section">
    <view class="form-label">检查结果</view>
    <view class="chip-grid" style="margin-bottom: 16rpx;">
      <view class="select-chip {{resultStatus === 'normal' ? 'active' : ''}}"
            bindtap="onResultStatus" data-status="normal">
        ✅ 一切正常
      </view>
      <view class="select-chip {{resultStatus === 'attention' ? 'active' : ''}}"
            bindtap="onResultStatus" data-status="attention">
        ⚠️ 需关注
      </view>
      <view class="select-chip {{resultStatus === 'abnormal' ? 'active' : ''}}"
            bindtap="onResultStatus" data-status="abnormal">
        ❌ 异常
      </view>
    </view>
    <textarea class="form-textarea" placeholder="检查结果详情、医生建议..."
              value="{{resultDetail}}" bindinput="onResultInput" maxlength="1000"/>
  </view>

  <!-- 医院 -->
  <view class="form-section">
    <view class="form-label">体检医院</view>
    <input class="form-input" placeholder="宠物医院名称"
           value="{{hospitalName}}" bindinput="onHospitalInput"/>
  </view>

  <!-- 费用 -->
  <view class="form-section">
    <view class="form-label">费用 <text class="label-hint">(可选)</text></view>
    <input class="form-input" type="digit" placeholder="元"
           value="{{cost}}" bindinput="onCostInput"/>
  </view>

  <!-- 下次体检 -->
  <view class="form-section">
    <view class="form-label">下次体检日期 <text class="label-hint">(可选)</text></view>
    <picker mode="date" value="{{nextDate}}" start="{{recordDate}}" bindchange="onNextDateChange">
      <view class="form-input picker-value">
        {{nextDate || '设置提醒日期'}}
        <text class="picker-arrow">▼</text>
      </view>
    </picker>
  </view>

  <!-- 提交 -->
  <view class="form-submit">
    <button class="submit-btn" bindtap="onSubmit" disabled="{{submitting}}">
      {{submitting ? '提交中...' : '记录完成'}}
    </button>
  </view>
</view>
