/* 猫粮详情页 - 手绘涂鸦风 */
.page {
  background: transparent;
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 140rpx;
}

/* ===== 头部卡片 ===== */
.header-card {
  display: flex;
  padding: 28rpx;
  background: var(--color-card);
  border: 2rpx solid rgba(56, 184, 232, 0.15);
  border-radius: var(--radius-lg);
  position: relative;
  box-shadow: 0 4rpx 16rpx rgba(56, 184, 232, 0.08);
}
.header-deco {
  position: absolute;
  top: -16rpx;
  right: 24rpx;
  font-size: 36rpx;
  transform: rotate(12deg);
}
.food-cover {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-md);
  flex-shrink: 0;
  background: var(--color-bg);
  border: 2rpx solid rgba(56, 184, 232, 0.12);
}
.header-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.food-brand {
  font-size: 24rpx;
  color: var(--color-placeholder);
  display: block;
}
.food-name {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text);
  margin: 8rpx 0 12rpx;
  line-height: 1.3;
}
.food-score-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.score-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(255, 184, 198, 0.15);
  padding: 4rpx 14rpx 4rpx 6rpx;
  border-radius: 20rpx;
}
.score-icon {
  width: 32rpx;
  height: 32rpx;
}
.score-num {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text);
}
.review-count {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}
.food-price {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-top: 10rpx;
}
.price-icon {
  width: 30rpx;
  height: 30rpx;
}
.price-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* ===== Section Tabs ===== */
.section-tabs {
  display: flex;
  margin-top: 24rpx;
  background: var(--color-card);
  border: 2rpx solid rgba(56, 184, 232, 0.12);
  border-radius: var(--radius-lg);
  padding: 8rpx;
}
.sec-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  border-radius: var(--radius-md);
  transition: all 0.3s;
}
.sec-tab.active {
  color: #fff;
  font-weight: 600;
  background: var(--color-primary);
}

/* ===== Section Content ===== */
.section {
  margin-top: 24rpx;
}

/* ===== 基本信息 - Info Grid ===== */
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.info-item {
  background: var(--color-card);
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  border: 1.5rpx solid rgba(56, 184, 232, 0.12);
  box-shadow: 0 2rpx 8rpx rgba(56, 184, 232, 0.04);
}
.info-label {
  font-size: 22rpx;
  color: var(--color-placeholder);
  display: block;
  margin-bottom: 6rpx;
}
.info-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}
.info-value.highlight {
  color: var(--color-primary);
}

/* 配料表 */
.ingredients-card {
  background: var(--color-card);
  border-radius: var(--radius-md);
  padding: 24rpx;
  border: 1.5rpx solid rgba(56, 184, 232, 0.12);
  margin-bottom: 20rpx;
}
.sub-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 12rpx;
}
.ingredients-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.7;
}

/* 标签 */
.food-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.tag {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  background: var(--color-secondary);
  color: var(--color-primary);
  border-radius: 32rpx;
  border: 1rpx solid rgba(56, 184, 232, 0.15);
}

/* ===== PGC 测评评分 ===== */
.pgc-header {
  margin-bottom: 20rpx;
}
.pgc-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
}
.radar-scores {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  border: 2rpx solid rgba(56, 184, 232, 0.12);
  box-shadow: 0 4rpx 16rpx rgba(56, 184, 232, 0.06);
}
.radar-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.radar-item:last-child {
  margin-bottom: 0;
}
.radar-label-left {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  width: 80rpx;
  flex-shrink: 0;
}
.radar-track {
  flex: 1;
  height: 20rpx;
  background: rgba(56, 184, 232, 0.08);
  border-radius: 10rpx;
  overflow: hidden;
  margin: 0 16rpx;
}
.radar-bar {
  height: 100%;
  background: var(--color-primary);
  border-radius: 10rpx;
  min-width: 16rpx;
  transition: width 0.5s ease;
}
.radar-score {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-primary);
  width: 48rpx;
  text-align: right;
}

/* ===== UGC 短评 ===== */
.ugc-item {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1.5rpx solid rgba(56, 184, 232, 0.1);
  box-shadow: 0 2rpx 8rpx rgba(56, 184, 232, 0.04);
}
.ugc-user-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.ugc-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  flex-shrink: 0;
  border: 2rpx solid rgba(56, 184, 232, 0.2);
}
.ugc-user-info {
  flex: 1;
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
}
.ugc-nickname {
  font-size: 26rpx;
  color: var(--color-text);
  font-weight: 600;
}
.ugc-time {
  font-size: 20rpx;
  color: var(--color-placeholder);
  margin-top: 4rpx;
}
.ugc-stars {
  display: flex;
  align-items: center;
  gap: 4rpx;
  flex-shrink: 0;
}
.ugc-star-icon {
  width: 28rpx;
  height: 28rpx;
}
.ugc-content {
  font-size: 26rpx;
  color: var(--color-text);
  line-height: 1.7;
}
.ugc-images {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}
.ugc-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-sm);
  border: 1.5rpx solid rgba(56, 184, 232, 0.1);
}

/* ===== 底部按钮 ===== */
.write-btn {
  position: fixed;
  bottom: 48rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: var(--color-primary);
  color: #FFF;
  font-size: 28rpx;
  font-weight: 600;
  padding: 22rpx 56rpx;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(56, 184, 232, 0.35);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}
.write-btn-icon {
  font-size: 30rpx;
}
.write-btn-text {
  font-size: 28rpx;
}

/* ===== 空状态 ===== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}
.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}
.empty-text {
  font-size: 26rpx;
  color: var(--color-placeholder);
}
