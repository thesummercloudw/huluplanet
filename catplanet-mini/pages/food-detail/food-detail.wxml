<view class="page" wx:if="{{food}}">
  <!-- 噪点纹理层 -->
  <view class="grain-overlay"></view>

  <!-- 头部卡片 -->
  <view class="header-card">
    <view class="header-deco">🐾</view>
    <image class="food-cover" src="{{food.image || '/images/food-placeholder.png'}}" mode="aspectFill"></image>
    <view class="header-info">
      <text class="food-brand">{{food.brand}}</text>
      <view class="food-name">{{food.name}}</view>
      <view class="food-score-row">
        <view class="score-badge" wx:if="{{food.avgScore > 0}}">
          <image class="score-icon" src="/images/icon-score.svg" mode="aspectFit"></image>
          <text class="score-num">{{food.avgScore}}</text>
        </view>
        <text class="review-count">{{food.reviewCount}}条评价</text>
      </view>
      <view class="food-price" wx:if="{{food.priceRange}}">
        <image class="price-icon" src="/images/icon-price.svg" mode="aspectFit"></image>
        <text class="price-text">{{food.priceRange}}</text>
      </view>
    </view>
  </view>

  <!-- Section Tabs -->
  <view class="section-tabs">
    <view class="sec-tab {{activeSection==='info'?'active':''}}" bindtap="switchSection" data-section="info">📋 基本信息</view>
    <view class="sec-tab {{activeSection==='pgc'?'active':''}}" bindtap="switchSection" data-section="pgc">📝 官方测评</view>
    <view class="sec-tab {{activeSection==='ugc'?'active':''}}" bindtap="switchSection" data-section="ugc">💬 用户短评</view>
  </view>

  <!-- 基本信息 -->
  <view class="section" wx:if="{{activeSection==='info'}}">
    <view class="info-grid">
      <view class="info-item">
        <text class="info-label">类型</text>
        <text class="info-value">{{food.foodType === 'main' ? '主粮' : food.foodType === 'wet' ? '湿粮' : food.foodType === 'snack' ? '零食' : '冻干'}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">适用阶段</text>
        <text class="info-value">{{food.ageStage === 'kitten' ? '幼猫' : food.ageStage === 'adult' ? '成猫' : food.ageStage === 'senior' ? '老年猫' : '全阶段'}}</text>
      </view>
      <view class="info-item" wx:if="{{food.proteinPct}}">
        <text class="info-label">粗蛋白</text>
        <text class="info-value highlight">{{food.proteinPct}}%</text>
      </view>
      <view class="info-item" wx:if="{{food.fatPct}}">
        <text class="info-label">粗脂肪</text>
        <text class="info-value highlight">{{food.fatPct}}%</text>
      </view>
    </view>
    <view class="ingredients-card" wx:if="{{food.ingredientsSummary}}">
      <view class="sub-title">🧾 配料表摘要</view>
      <text class="ingredients-text">{{food.ingredientsSummary}}</text>
    </view>
    <view class="food-tags" wx:if="{{food.tags && food.tags.length > 0}}">
      <text class="tag" wx:for="{{food.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
    </view>
  </view>

  <!-- PGC 官方测评 -->
  <view class="section" wx:if="{{activeSection==='pgc'}}">
    <block wx:if="{{pgcReview}}">
      <view class="pgc-header">
        <view class="pgc-title">{{pgcReview.title}}</view>
      </view>
      <view class="radar-scores">
        <view class="radar-item">
          <text class="radar-label-left">原料</text>
          <view class="radar-track">
            <view class="radar-bar" style="width: {{pgcReview.scoreIngredient * 10}}%"></view>
          </view>
          <text class="radar-score">{{pgcReview.scoreIngredient}}</text>
        </view>
        <view class="radar-item">
          <text class="radar-label-left">营养</text>
          <view class="radar-track">
            <view class="radar-bar" style="width: {{pgcReview.scoreNutrition * 10}}%"></view>
          </view>
          <text class="radar-score">{{pgcReview.scoreNutrition}}</text>
        </view>
        <view class="radar-item">
          <text class="radar-label-left">性价比</text>
          <view class="radar-track">
            <view class="radar-bar" style="width: {{pgcReview.scoreValue * 10}}%"></view>
          </view>
          <text class="radar-score">{{pgcReview.scoreValue}}</text>
        </view>
        <view class="radar-item">
          <text class="radar-label-left">适口性</text>
          <view class="radar-track">
            <view class="radar-bar" style="width: {{pgcReview.scorePalatability * 10}}%"></view>
          </view>
          <text class="radar-score">{{pgcReview.scorePalatability}}</text>
        </view>
        <view class="radar-item">
          <text class="radar-label-left">安全性</text>
          <view class="radar-track">
            <view class="radar-bar" style="width: {{pgcReview.scoreSafety * 10}}%"></view>
          </view>
          <text class="radar-score">{{pgcReview.scoreSafety}}</text>
        </view>
      </view>
    </block>
    <view class="empty" wx:else>
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无官方测评</text>
    </view>
  </view>

  <!-- UGC 短评 -->
  <view class="section" wx:if="{{activeSection==='ugc'}}">
    <view class="ugc-item" wx:for="{{ugcReviews}}" wx:key="reviewId">
      <view class="ugc-user-row">
        <image class="ugc-avatar" src="{{item.avatar || '/images/cat-icon.svg'}}" mode="aspectFill"></image>
        <view class="ugc-user-info">
          <text class="ugc-nickname">{{item.nickname || '匿名铲屎官'}}</text>
          <text class="ugc-time">{{item.createdAt}}</text>
        </view>
        <view class="ugc-stars">
          <image wx:if="{{item.score >= 1}}" class="ugc-star-icon" src="/images/icon-score.svg" mode="aspectFit"></image>
          <image wx:if="{{item.score >= 2}}" class="ugc-star-icon" src="/images/icon-score.svg" mode="aspectFit"></image>
          <image wx:if="{{item.score >= 3}}" class="ugc-star-icon" src="/images/icon-score.svg" mode="aspectFit"></image>
          <image wx:if="{{item.score >= 4}}" class="ugc-star-icon" src="/images/icon-score.svg" mode="aspectFit"></image>
          <image wx:if="{{item.score >= 5}}" class="ugc-star-icon" src="/images/icon-score.svg" mode="aspectFit"></image>
        </view>
      </view>
      <view class="ugc-content">{{item.content}}</view>
      <view class="ugc-images" wx:if="{{item.images && item.images.length > 0}}">
        <image wx:for="{{item.images}}" wx:for-item="img" wx:key="*this" src="{{img}}" mode="aspectFill" class="ugc-img"></image>
      </view>
    </view>
    <view class="empty" wx:if="{{ugcReviews.length === 0}}">
      <text class="empty-icon">💬</text>
      <text class="empty-text">暂无用户短评，快来分享吧~</text>
    </view>
  </view>

  <!-- 写短评按钮 -->
  <view class="write-btn" bindtap="goWriteReview">
    <text class="write-btn-icon">✍️</text>
    <text class="write-btn-text">我家猫吃过</text>
  </view>
</view>
