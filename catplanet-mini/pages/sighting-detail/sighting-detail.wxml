<view class="container sighting-detail-page">
  <view class="grain-overlay"></view>

  <!-- 出没详情卡 -->
  <view class="detail-card" wx:if="{{sighting}}">
    <image class="detail-img" src="{{sighting.image}}" mode="aspectFill" bindtap="previewImage"></image>
    <view class="detail-info">
      <view class="detail-publisher" wx:if="{{publisherNickname}}">
        <image class="detail-publisher-avatar" src="{{publisherAvatar || '/images/cat-icon.svg'}}" mode="aspectFill"></image>
        <text class="detail-publisher-name">{{publisherNickname}}</text>
      </view>
      <view class="detail-address"><image class="inline-loc-icon" src="/images/icon-location.svg" mode="aspectFit"></image> {{sighting.address || '未知地点'}}</view>
      <view class="detail-content" wx:if="{{sighting.content}}">{{sighting.content}}</view>
      <view class="detail-meta">
        <text class="detail-time">{{sighting.timeStr}}</text>
        <view class="detail-comment-wrap">
          <image class="detail-comment-icon" src="/images/icon-comment.svg" mode="aspectFit"></image>
          <text class="detail-comment-count">{{sighting.commentCount || 0}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 评论区 -->
  <view class="comment-section">
    <view class="comment-title">评论 ({{comments.length || 0}})</view>

    <view class="comment-list" wx:if="{{comments.length > 0}}">
      <view class="comment-item" wx:for="{{comments}}" wx:key="commentId">
        <view class="comment-header">
          <image class="comment-avatar" src="{{item.avatar || '/images/cat-icon.svg'}}" mode="aspectFill" lazy-load></image>
          <view class="comment-user-info">
            <text class="comment-nickname">{{item.nickname || '匿名用户'}}</text>
            <text class="comment-time">{{item.timeStr}}</text>
          </view>
          <text class="comment-delete" wx:if="{{item.isMine}}" bindtap="deleteComment" data-id="{{item.commentId}}">删除</text>
        </view>
        <view class="comment-content">{{item.content}}</view>
        <view class="comment-images" wx:if="{{item.images && item.images.length > 0}}">
          <image class="comment-img" wx:for="{{item.images}}" wx:for-item="img" wx:key="*this" src="{{img}}" mode="aspectFill" lazy-load bindtap="previewCommentImage" data-urls="{{item.images}}" data-current="{{img}}"></image>
        </view>
      </view>
    </view>

    <view class="comment-empty" wx:if="{{comments.length === 0 && !loading}}">
      <text class="comment-empty-text">暂无评论，来说点什么吧~</text>
    </view>
  </view>

  <!-- 底部评论输入栏 -->
  <view class="comment-bar">
    <view class="comment-input-wrap">
      <textarea class="comment-input" placeholder="说点什么..." maxlength="500" value="{{inputContent}}" bindinput="onCommentInput" auto-height="{{true}}" disable-default-padding="{{true}}"></textarea>
      <text class="comment-char-count">{{inputContent.length || 0}}/500</text>
    </view>
    <view class="comment-actions">
      <view class="comment-img-btn" bindtap="chooseCommentImages">
        <image class="comment-img-icon" src="/images/icon-image.svg" mode="aspectFit"></image>
        <text class="comment-img-text">图片</text>
      </view>
      <view class="comment-send-btn {{canSend ? '' : 'disabled'}}" bindtap="sendComment">发送</view>
    </view>
  </view>

  <!-- 已选图片预览 -->
  <view class="selected-images" wx:if="{{selectedImages.length > 0}}">
    <view class="selected-img-item" wx:for="{{selectedImages}}" wx:key="index">
      <image class="selected-img" src="{{item.tempUrl}}" mode="aspectFill"></image>
      <view class="selected-img-remove" bindtap="removeImage" data-index="{{index}}">×</view>
    </view>
  </view>
</view>
