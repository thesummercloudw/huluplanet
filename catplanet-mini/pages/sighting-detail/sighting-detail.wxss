.sighting-detail-page {
  padding-bottom: 200rpx;
}

/* 详情卡片 */
.detail-card {
  background: rgba(255, 255, 255, 0.72);
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 1.5rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: var(--shadow-card);
  margin-bottom: 32rpx;
}

.detail-img {
  width: 100%;
  height: 480rpx;
}

.detail-info {
  padding: 28rpx 32rpx;
}

.detail-publisher {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.detail-publisher-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  border: 2rpx solid rgba(56, 184, 232, 0.2);
}

.detail-publisher-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
}

.detail-address {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 500;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}

.detail-content {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.detail-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.detail-comment-wrap {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.detail-comment-icon {
  width: 32rpx;
  height: 32rpx;
  vertical-align: middle;
}

.detail-time {
  font-size: 24rpx;
  color: var(--color-placeholder);
}

.detail-comment-count {
  font-size: 24rpx;
  color: var(--color-placeholder);
}

/* 评论区 */
.comment-section {
  margin-bottom: 32rpx;
}

.comment-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 24rpx;
}

.comment-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.comment-item {
  background: rgba(255, 255, 255, 0.72);
  border-radius: var(--radius-md);
  padding: 24rpx;
  border: 1.5rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: var(--shadow-card);
}

.comment-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.comment-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  flex-shrink: 0;
  border: 2rpx solid rgba(56, 184, 232, 0.15);
}

.comment-user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.comment-nickname {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text);
}

.comment-time {
  font-size: 22rpx;
  color: var(--color-placeholder);
  margin-top: 2rpx;
}

.comment-content {
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.6;
  margin-bottom: 12rpx;
  word-break: break-all;
}

.comment-images {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.comment-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-sm);
  object-fit: cover;
}

.comment-delete {
  font-size: 22rpx;
  color: #ff6b6b;
  flex-shrink: 0;
}

.comment-empty {
  text-align: center;
  padding: 60rpx 0;
}

.comment-empty-text {
  font-size: 26rpx;
  color: var(--color-placeholder);
}

/* 底部评论栏 */
.comment-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.92);
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(56, 184, 232, 0.12);
  z-index: 100;
}

.comment-input-wrap {
  position: relative;
  margin-bottom: 16rpx;
}

.comment-input {
  width: 100%;
  min-height: 64rpx;
  max-height: 200rpx;
  background: rgba(56, 184, 232, 0.06);
  border-radius: var(--radius-md);
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: var(--color-text);
  box-sizing: border-box;
  border: 1rpx solid rgba(56, 184, 232, 0.15);
}

.comment-char-count {
  position: absolute;
  bottom: 8rpx;
  right: 16rpx;
  font-size: 20rpx;
  color: var(--color-placeholder);
}

.comment-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.comment-img-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
}

.comment-img-icon {
  width: 40rpx;
  height: 40rpx;
}

.comment-img-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.comment-send-btn {
  padding: 12rpx 32rpx;
  background: #38B8E8;
  color: #fff;
  border-radius: var(--radius-md);
  font-size: 26rpx;
  font-weight: 500;
}

.comment-send-btn.disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* 已选图片预览 */
.selected-images {
  position: fixed;
  bottom: calc(160rpx + env(safe-area-inset-bottom));
  left: 32rpx;
  right: 32rpx;
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  background: rgba(255, 255, 255, 0.9);
  padding: 16rpx;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  z-index: 101;
}

.selected-img-item {
  position: relative;
  width: 120rpx;
  height: 120rpx;
}

.selected-img {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-sm);
}

.selected-img-remove {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 36rpx;
  height: 36rpx;
  background: #ff6b6b;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  line-height: 36rpx;
  text-align: center;
}
