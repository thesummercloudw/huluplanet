.edit-page {
  padding-bottom: 60rpx;
}

/* 头像选择 */
.avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.avatar-wrapper {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  overflow: hidden;
  position: relative;
  background: var(--color-card);
  border: 4rpx dashed #ccc;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.avatar-hint {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.avatar-loading {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 22rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: var(--color-card);
  border-radius: var(--radius-md);
  padding: 0 28rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.picker-value {
  line-height: 88rpx;
  color: var(--color-text);
}

.row-group {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--color-card);
  border-radius: var(--radius-md);
  padding: 20rpx 28rpx;
}

.row-group .form-label {
  margin-bottom: 0;
  font-size: 30rpx;
  color: var(--color-text);
}

.submit-btn {
  margin-top: 48rpx;
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

/* 品种识别 */
.breed-picker-wrapper {
  position: relative;
}

.breed-recognizing {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
}

.recognizing-text {
  font-size: 24rpx;
  color: #FF8C69;
  animation: blink 1.2s infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

/* ====== 🎆 烟火彩蛋动画 ====== */
.fireworks-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 9999;
  background: rgba(0, 0, 0, 0.85);
  animation: fadeInOverlay 0.3s ease-out;
}

@keyframes fadeInOverlay {
  from { opacity: 0; }
  to { opacity: 1; }
}

.fireworks-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.fireworks-title {
  position: absolute;
  top: 42%;
  left: 50%;
  transform: translateX(-50%);
  font-size: 48rpx;
  font-weight: bold;
  color: #FFD700;
  text-shadow: 0 0 30rpx rgba(255, 215, 0, 0.9), 0 0 60rpx rgba(255, 100, 50, 0.5);
  z-index: 10;
  white-space: nowrap;
  animation: titlePop 0.8s 0.3s ease-out both;
}

@keyframes titlePop {
  0% { transform: translateX(-50%) scale(0); opacity: 0; }
  50% { transform: translateX(-50%) scale(1.3); }
  70% { transform: translateX(-50%) scale(0.95); }
  100% { transform: translateX(-50%) scale(1); opacity: 1; }
}
