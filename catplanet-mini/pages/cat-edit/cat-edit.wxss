/* ======== 猫咪编辑表单 - 手绘涂鸦风 ======== */
.form-page { padding-bottom: 60rpx; }

.form-title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 40rpx;
  color: var(--color-text);
  display: flex;
  align-items: center;
}
.form-title-icon { width: 40rpx; height: 40rpx; margin-right: 8rpx; }

.form-section { margin-bottom: 36rpx; }

.form-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
}
.required-star { color: #FF6B6B; font-weight: 700; }

.form-input {
  background: var(--color-card);
  border-radius: var(--radius-md);
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: var(--color-text);
  box-shadow: var(--shadow-card);
  box-sizing: border-box;
  width: 100%;
  height: 88rpx;
  line-height: 40rpx;
}

.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.picker-arrow { font-size: 20rpx; color: var(--color-text-secondary); }
.placeholder-text { color: var(--color-placeholder); }

/* 头像区域 */
.avatar-section {
  display: flex;
  justify-content: center;
}

.avatar-wrapper {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  overflow: hidden;
  position: relative;
  background: rgba(56, 184, 232, 0.05);
  border: 3rpx dashed rgba(56, 184, 232, 0.4);
}

.avatar-img { width: 100%; height: 100%; }

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.avatar-icon-svg {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
}

.avatar-hint {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.avatar-loading {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 22rpx;
}

/* 开关行 */
.row-group {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--color-card);
  border-radius: var(--radius-md);
  padding: 24rpx 28rpx;
  box-shadow: var(--shadow-card);
}
.row-label {
  font-size: 30rpx;
  color: var(--color-text);
}

/* 提交按钮 */
.form-submit { margin-top: 60rpx; }
.submit-btn {
  background: var(--color-accent) !important;
  color: #fff !important;
  border-radius: var(--radius-md) !important;
  font-size: 30rpx;
  padding: 24rpx 0;
  border: none;
}
.submit-btn[disabled] { opacity: 0.6; }
.submit-btn::after { border: none; }

/* 品种识别 */
.breed-picker-wrapper { position: relative; }

.breed-recognizing {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
}

.recognizing-text {
  font-size: 24rpx;
  color: var(--color-accent);
  animation: blink 1.2s infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

/* ====== 🎆 烟火彩蛋动画 ====== */
.fireworks-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 9999;
  background: rgba(0, 0, 0, 0.85);
  animation: fadeInOverlay 0.3s ease-out;
}

@keyframes fadeInOverlay {
  from { opacity: 0; }
  to { opacity: 1; }
}

.fireworks-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.fireworks-title {
  position: absolute;
  top: 42%;
  left: 50%;
  transform: translateX(-50%);
  font-size: 48rpx;
  font-weight: bold;
  color: #FFD700;
  text-shadow: 0 0 30rpx rgba(255, 215, 0, 0.9), 0 0 60rpx rgba(255, 100, 50, 0.5);
  z-index: 10;
  white-space: nowrap;
  animation: titlePop 0.8s 0.3s ease-out both;
}

@keyframes titlePop {
  0% { transform: translateX(-50%) scale(0); opacity: 0; }
  50% { transform: translateX(-50%) scale(1.3); }
  70% { transform: translateX(-50%) scale(0.95); }
  100% { transform: translateX(-50%) scale(1); opacity: 1; }
}
