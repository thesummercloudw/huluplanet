.edit-page {
  padding-bottom: 60rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: var(--color-card);
  border-radius: var(--radius-md);
  padding: 0 28rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.picker-value {
  line-height: 88rpx;
  color: var(--color-text);
}

.row-group {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--color-card);
  border-radius: var(--radius-md);
  padding: 20rpx 28rpx;
}

.row-group .form-label {
  margin-bottom: 0;
  font-size: 30rpx;
  color: var(--color-text);
}

.submit-btn {
  margin-top: 48rpx;
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
}
