.guide-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.guide-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.guide-emoji {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.guide-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.guide-desc {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.tab-bar {
  display: flex;
  width: 100%;
  margin-bottom: 48rpx;
  background: var(--color-card);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  transition: all 0.3s;
}

.tab-item.active {
  color: var(--color-primary);
  font-weight: 600;
  background: var(--color-secondary);
}

.form-section {
  width: 100%;
}

.form-input {
  width: 100%;
  height: 96rpx;
  background: var(--color-card);
  border-radius: var(--radius-md);
  padding: 0 32rpx;
  font-size: 30rpx;
  margin-bottom: 40rpx;
  box-sizing: border-box;
}
