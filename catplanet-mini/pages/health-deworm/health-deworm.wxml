<view class="container form-page">
  <view class="grain-overlay"></view>
  <view class="form-title"><image class="form-title-icon" src="/images/icon-health-deworm.svg" mode="aspectFit"></image> 驱虫记录</view>

  <!-- 选猫 -->
  <view class="form-section">
    <view class="form-label">选择猫咪</view>
    <scroll-view class="cat-picker" scroll-x>
      <view class="cat-chip {{selectedCatId === item.catId ? 'active' : ''}}"
            wx:for="{{cats}}" wx:key="catId"
            bindtap="onCatSelect" data-id="{{item.catId}}">
        <text>{{item.name}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 驱虫类型 -->
  <view class="form-section">
    <view class="form-label">驱虫类型</view>
    <view class="chip-grid">
      <view class="select-chip {{dewormType === item.value ? 'active' : ''}}"
            wx:for="{{dewormTypes}}" wx:key="value"
            bindtap="onDewormType" data-type="{{item.value}}">
        <image class="chip-icon-img" src="{{item.icon}}" mode="aspectFit"></image>
        <text>{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 品牌快选 -->
  <view class="form-section">
    <view class="form-label">驱虫产品</view>
    <view class="chip-grid">
      <view class="select-chip {{productName === item ? 'active' : ''}}"
            wx:for="{{productPresets}}" wx:key="*this"
            bindtap="onProductPreset" data-name="{{item}}">
        {{item}}
      </view>
    </view>
    <input class="form-input mt-16" placeholder="或输入其他产品名称"
           value="{{productName}}" bindinput="onProductInput"/>
  </view>

  <!-- 日期 -->
  <view class="form-section">
    <view class="form-label">驱虫日期</view>
    <picker mode="date" value="{{recordDate}}" bindchange="onDateChange">
      <view class="form-input picker-value">
        {{recordDate || '选择日期'}}
        <text class="picker-arrow">▼</text>
      </view>
    </picker>
  </view>

  <!-- 下次驱虫提醒 -->
  <view class="form-section">
    <view class="form-label">下次驱虫日期 <text class="label-hint">(可选)</text></view>
    <view class="chip-grid" style="margin-bottom: 16rpx;">
      <view class="select-chip {{nextInterval === item.days ? 'active' : ''}}"
            wx:for="{{intervalPresets}}" wx:key="days"
            bindtap="onIntervalPreset" data-days="{{item.days}}">
        {{item.label}}
      </view>
    </view>
    <picker mode="date" value="{{nextDate}}" start="{{recordDate}}" bindchange="onNextDateChange">
      <view class="form-input picker-value">
        {{nextDate || '或手动选择日期'}}
        <text class="picker-arrow">▼</text>
      </view>
    </picker>
  </view>

  <!-- 备注 -->
  <view class="form-section">
    <view class="form-label">备注 <text class="label-hint">(可选)</text></view>
    <textarea class="form-textarea" placeholder="驱虫反应、体重等信息..."
              value="{{note}}" bindinput="onNoteInput" maxlength="500"/>
  </view>

  <!-- 提交 -->
  <view class="form-submit">
    <button class="submit-btn" bindtap="onSubmit" disabled="{{submitting}}">
      {{submitting ? '提交中...' : '记录完成'}}
    </button>
  </view>
</view>
