<view class="page">
  <!-- 磨砂噪点纹理层 -->
  <view class="grain-overlay"></view>

  <!-- 封面上传 -->
  <view class="section">
    <view class="section-title">猫咪照片 *</view>
    <view class="image-upload-area">
      <view class="image-list">
        <view class="image-item" wx:for="{{images}}" wx:key="index">
          <image src="{{item}}" mode="aspectFill" class="uploaded-img"></image>
          <view class="remove-btn" catchtap="removeImage" data-index="{{index}}">×</view>
        </view>
        <view class="image-add" bindtap="chooseImage" wx:if="{{images.length < 6}}">
          <text class="add-icon">+</text>
          <text class="add-text">添加照片</text>
        </view>
      </view>
      <text class="image-tip">最多6张，第一张为封面</text>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="section">
    <view class="section-title">基本信息</view>
    <view class="form-item">
      <text class="form-label">名字 *</text>
      <input class="form-input" placeholder="给它起个名字" bindinput="onInput" data-field="name" value="{{form.name}}"/>
    </view>
    <view class="form-item">
      <text class="form-label">性别</text>
      <view class="gender-select">
        <view class="gender-item {{form.gender==='male'?'active':''}}" bindtap="setGender" data-gender="male">♂ 弟弟</view>
        <view class="gender-item {{form.gender==='female'?'active':''}}" bindtap="setGender" data-gender="female">♀ 妹妹</view>
        <view class="gender-item {{form.gender==='unknown'?'active':''}}" bindtap="setGender" data-gender="unknown">未知</view>
      </view>
    </view>
    <view class="form-item">
      <text class="form-label">年龄估计</text>
      <input class="form-input" placeholder="如：约6月龄、约2岁" bindinput="onInput" data-field="ageEstimate" value="{{form.ageEstimate}}"/>
    </view>
    <view class="form-item">
      <text class="form-label">品种估计</text>
      <input class="form-input" placeholder="如：橘猫、英短蓝猫" bindinput="onInput" data-field="breedEstimate" value="{{form.breedEstimate}}"/>
    </view>
    <view class="form-item">
      <text class="form-label">所在城市 *</text>
      <input class="form-input" placeholder="如：南京" bindinput="onInput" data-field="city" value="{{form.city}}"/>
    </view>
  </view>

  <!-- 详细描述 -->
  <view class="section">
    <view class="section-title">详细描述</view>
    <view class="form-item">
      <text class="form-label">性格描述</text>
      <textarea class="form-textarea" placeholder="它的性格怎么样？亲人吗？" bindinput="onInput" data-field="personality" value="{{form.personality}}"></textarea>
    </view>
    <view class="form-item">
      <text class="form-label">送养原因</text>
      <textarea class="form-textarea" placeholder="为什么需要为它找新家？" bindinput="onInput" data-field="reasonForAdoption" value="{{form.reasonForAdoption}}"></textarea>
    </view>
  </view>

  <!-- 健康状况 -->
  <view class="section">
    <view class="section-title">健康状况</view>
    <view class="form-item">
      <text class="form-label">疫苗</text>
      <input class="form-input" placeholder="如：已打3针、未打" bindinput="onHealthInput" data-field="vaccine" value="{{form.healthStatus.vaccine}}"/>
    </view>
    <view class="form-item">
      <text class="form-label">驱虫</text>
      <input class="form-input" placeholder="如：已做、未做" bindinput="onHealthInput" data-field="deworm" value="{{form.healthStatus.deworm}}"/>
    </view>
    <view class="form-item">
      <text class="form-label">绝育</text>
      <input class="form-input" placeholder="如：已绝育、未绝育" bindinput="onHealthInput" data-field="neutered" value="{{form.healthStatus.neutered}}"/>
    </view>
  </view>

  <!-- 联系方式 -->
  <view class="section">
    <view class="section-title">联系方式</view>
    <view class="form-item">
      <text class="form-label">联系方式 *</text>
      <input class="form-input" placeholder="微信号/手机号" bindinput="onInput" data-field="contactMethod" value="{{form.contactMethod}}"/>
    </view>
    <text class="contact-tip">联系方式仅管理员可见，不会公开展示</text>
  </view>

  <!-- 发布按钮 -->
  <view class="submit-area">
    <view class="submit-btn {{submitting?'disabled':''}}" bindtap="submit">{{submitting ? '发布中...' : '发布领养信息'}}</view>
  </view>
</view>
