.page {
  padding: 0 24rpx 24rpx;
  background: transparent;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.section {
  background: rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(20px) saturate(1.2);
  -webkit-backdrop-filter: blur(20px) saturate(1.2);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

/* 图片上传 */
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.uploaded-img {
  width: 100%;
  height: 100%;
}

.remove-btn {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 28rpx;
  text-align: center;
  line-height: 40rpx;
  border-radius: 50%;
}

.image-add {
  width: 180rpx;
  height: 180rpx;
  border: 2rpx dashed rgba(53, 200, 180, 0.4);
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(53, 200, 180, 0.05);
}

.add-icon {
  font-size: 48rpx;
  color: #35C8B4;
}

.add-text {
  font-size: 20rpx;
  color: #999;
  margin-top: 6rpx;
}

.image-tip {
  font-size: 20rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 表单 */
.form-item {
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 10rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 72rpx;
  font-size: 26rpx;
  color: #333;
  background: rgba(245, 245, 245, 0.8);
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  font-size: 26rpx;
  color: #333;
  background: rgba(245, 245, 245, 0.8);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  box-sizing: border-box;
}

/* 性别选择 */
.gender-select {
  display: flex;
  gap: 16rpx;
}

.gender-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #666;
  background: rgba(245, 245, 245, 0.8);
  border: 1rpx solid transparent;
}

.gender-item.active {
  background: rgba(53, 200, 180, 0.12);
  color: #35C8B4;
  font-weight: 600;
  border-color: rgba(53, 200, 180, 0.3);
}

/* 联系方式提示 */
.contact-tip {
  font-size: 20rpx;
  color: #FF9843;
  margin-top: 8rpx;
}

/* 提交按钮 */
.submit-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 48rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.submit-btn {
  background: linear-gradient(135deg, #35C8B4, #A4CF4A);
  color: #FFF;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(53, 200, 180, 0.3);
}

.submit-btn.disabled {
  opacity: 0.6;
}
