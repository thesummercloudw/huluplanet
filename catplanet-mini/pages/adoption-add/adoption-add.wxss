.page {
  padding: 0 24rpx 24rpx;
  background: transparent;
  min-height: 100vh;
  padding-bottom: 200rpx;
}

.section {
  background: rgba(255, 255, 255, 0.72);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1.5rpx solid rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

/* 图片上传 */
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.uploaded-img {
  width: 100%;
  height: 100%;
}

.remove-btn {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 28rpx;
  text-align: center;
  line-height: 40rpx;
  border-radius: 50%;
}

.image-add {
  width: 180rpx;
  height: 180rpx;
  border: 2rpx dashed rgba(56, 184, 232, 0.4);
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(56, 184, 232, 0.05);
}

.add-icon {
  font-size: 48rpx;
  color: #38B8E8;
}

.add-text {
  font-size: 20rpx;
  color: #999;
  margin-top: 6rpx;
}

.image-tip {
  font-size: 20rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 表单 */
.form-item {
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 10rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 72rpx;
  font-size: 26rpx;
  color: #333;
  background: rgba(245, 245, 245, 0.8);
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  font-size: 26rpx;
  color: #333;
  background: rgba(245, 245, 245, 0.8);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  box-sizing: border-box;
}

/* 性别选择 */
.gender-select {
  display: flex;
  gap: 16rpx;
}

.gender-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #666;
  background: rgba(245, 245, 245, 0.8);
  border: 1rpx solid transparent;
}

.gender-item.active {
  background: rgba(56, 184, 232, 0.12);
  color: #38B8E8;
  font-weight: 600;
  border-color: rgba(56, 184, 232, 0.3);
}

/* 联系方式提示 */
.contact-tip {
  font-size: 20rpx;
  color: #FF9843;
  margin-top: 12rpx;
  padding-bottom: 16rpx;
  display: block;
}

/* 地区选择 */
.region-picker-value {
  width: 100%;
  height: 72rpx;
  font-size: 26rpx;
  color: #333;
  background: rgba(245, 245, 245, 0.8);
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.region-picker-value.placeholder {
  color: #999;
}

.location-btn {
  display: inline-flex;
  align-items: center;
  font-size: 22rpx;
  color: #38B8E8;
  margin-top: 10rpx;
}

.location-btn .loc-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 6rpx;
  vertical-align: middle;
}

/* 下拉选择器 */
.picker-value {
  width: 100%;
  height: 72rpx;
  font-size: 26rpx;
  color: #333;
  background: rgba(245, 245, 245, 0.8);
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-value.placeholder {
  color: #999;
}

.picker-arrow {
  font-size: 24rpx;
  color: #999;
}

/* 记忆提示 */
.memory-hint {
  font-size: 20rpx;
  color: #38B8E8;
  margin-top: 6rpx;
  display: block;
}

/* 提交按钮 */
.submit-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 48rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.9);
}

.submit-btn {
  background: #38B8E8;
  color: #FFF;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(56, 184, 232, 0.3);
}

.submit-btn.disabled {
  opacity: 0.6;
}
