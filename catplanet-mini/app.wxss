/**app.wxss - 全局样式（手绘涂鸦风 · 奶油底+天蓝+青柠）**/
page {
  --color-primary: #38B8E8;
  --color-primary-light: #B8E8F8;
  --color-secondary: #E8F7D6;
  --color-accent: #8EBD3C;
  --color-bg: #F7F5ED;
  --color-bg-gradient: #F7F5ED;
  --color-card: rgba(255, 255, 255, 0.72);
  --color-card-solid: #FFFFFF;
  --color-text: #2A2A2A;
  --color-text-secondary: #5A5A5A;
  --color-placeholder: #9A9A9A;
  --color-border: rgba(56, 184, 232, 0.15);
  --color-pink: #FFB8C6;
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 32rpx;
  --shadow-card: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  --glass-blur: blur(20px);
  --glass-saturate: saturate(1.1);
  
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: var(--color-text);
  background: var(--color-bg-gradient);
  background-color: #FDFCF8;
  box-sizing: border-box;
}

.container {
  padding: 32rpx;
  min-height: 100vh;
}

.btn-primary {
  background: var(--color-primary);
  color: #fff;
  border: none;
  border-radius: var(--radius-md);
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(56, 184, 232, 0.2);
}

.btn-primary::after {
  border: none;
}

.card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-card);
  border: 1.5rpx solid rgba(0, 0, 0, 0.06);
  margin-bottom: 24rpx;
}

/* 通用定位小图标（行内） */
.inline-loc-icon {
  width: 28rpx;
  height: 28rpx;
  vertical-align: middle;
  margin-right: 4rpx;
}

/* 噪点纹理层 - 保留但降低透明度，轻微纸质感 */
.grain-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 9999;
  opacity: 0.12;
  background-image: url('data:image/png;base64,');
  background-size: 150rpx 150rpx;
  background-repeat: repeat;
  mix-blend-mode: overlay;
}
