/**app.wxss - 全局样式（柠檬汽水风 · 磨砂胶片感）**/
page {
  --color-primary: #35C8B4;
  --color-primary-light: #C2F2E4;
  --color-secondary: #EDF7BE;
  --color-accent: #A4CF4A;
  --color-bg: #C2F2E4;
  --color-bg-gradient: linear-gradient(160deg, #C2F2E4 0%, #d8f5e8 25%, #EDF7BE 60%, #e0f5d0 100%);
  --color-card: rgba(255, 255, 255, 0.45);
  --color-card-solid: #FFFFFF;
  --color-text: #1A6B5A;
  --color-text-secondary: #2D8A74;
  --color-placeholder: #7ABFB0;
  --color-border: rgba(53, 200, 180, 0.18);
  --color-pink: #FFB8C6;
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 32rpx;
  --shadow-card: 0 4rpx 20rpx rgba(53, 200, 180, 0.08);
  --glass-blur: blur(36px);
  --glass-saturate: saturate(1.35);
  
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: var(--color-text);
  background: var(--color-bg-gradient);
  background-color: var(--color-bg);
  box-sizing: border-box;
}

.container {
  padding: 32rpx;
  min-height: 100vh;
}

.btn-primary {
  background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
  color: #fff;
  border: none;
  border-radius: var(--radius-md);
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(53, 200, 180, 0.25);
}

.btn-primary::after {
  border: none;
}

.card {
  background: var(--color-card);
  backdrop-filter: var(--glass-blur) var(--glass-saturate);
  -webkit-backdrop-filter: var(--glass-blur) var(--glass-saturate);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  margin-bottom: 24rpx;
}

/* 磨砂噪点纹理层 - 需要在页面最外层添加 .grain-overlay 元素 */
.grain-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 9999;
  opacity: 0.45;
  background-image: url('/images/grain-texture.png');
  background-size: 150rpx 150rpx;
  background-repeat: repeat;
  mix-blend-mode: overlay;
}
