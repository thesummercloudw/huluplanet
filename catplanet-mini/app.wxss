/**app.wxss - 全局样式（海盐白桃风）**/
page {
  --color-primary: #FF8C69;
  --color-primary-light: #FFB5A0;
  --color-secondary: #FFD4C4;
  --color-bg: #FFF5F0;
  --color-card: #FFFFFF;
  --color-text: #333333;
  --color-text-secondary: #888888;
  --color-border: #F0E6E2;
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 32rpx;
  --shadow-card: 0 4rpx 20rpx rgba(255, 140, 105, 0.08);
  
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: var(--color-text);
  background-color: var(--color-bg);
  box-sizing: border-box;
}

.container {
  padding: 32rpx;
  min-height: 100vh;
}

.btn-primary {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: #fff;
  border: none;
  border-radius: var(--radius-md);
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
}

.btn-primary::after {
  border: none;
}

.card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-card);
  margin-bottom: 24rpx;
}
